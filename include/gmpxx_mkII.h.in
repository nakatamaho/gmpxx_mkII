namespace gmpxx_mkII_detail {

inline std::uint64_t prec_of(mpf_class const& x) {
    return static_cast<std::uint64_t>(x.get_prec());
}

template<class Op, class X>
inline std::uint64_t prec_of(unary_expr<Op, X> const& e) {
    return e.suggested_prec();
}

template<class Op, class L, class R>
inline std::uint64_t prec_of(binary_expr<Op, L, R> const& e) {
    return e.suggested_prec();
}

}  // namespace gmpxx_mkII_detail

template<class Op, class X>
struct [[nodiscard]] unary_expr : expr_base<unary_expr<Op, X>> {
    using result_type = gmpxx_mkII_detail::result_or_self_t<X>;

    X const& x;

    explicit unary_expr(X const& x_) : x(x_) {}

    [[nodiscard]] X const& operand() const noexcept {
        return x;
    }

    [[nodiscard]] std::uint64_t suggested_prec_impl() const {
        if constexpr (gmpxx_mkII_detail::has_mpf_precision_v<X>) {
            return gmpxx_mkII_detail::prec_of(x);
        } else {
            return gmpxx_mkII_detail::thread_default_prec();
        }
    }

    [[nodiscard]] bool contains_address(mpf_class const* p) const {
        if constexpr (std::same_as<X, mpf_class>) {
            return &x == p;
        } else if constexpr (scalar_operand<X> || mpz_operand<X> || mpq_operand<X>) {
            return false;
        } else {
            return x.contains_address(p);
        }
    }

    [[nodiscard]] bool contains_address(mpz_class const* p) const {
        if constexpr (std::same_as<X, mpz_class>) {
            return &x == p;
        } else if constexpr (scalar_operand<X> || std::same_as<X, mpf_class> ||
                             std::same_as<X, mpq_class>) {
            return false;
        } else {
            return x.contains_address(p);
        }
    }

    [[nodiscard]] bool contains_address(mpq_class const* p) const {
        if constexpr (std::same_as<X, mpq_class>) {
            return &x == p;
        } else if constexpr (scalar_operand<X> || std::same_as<X, mpf_class> ||
                             std::same_as<X, mpz_class>) {
            return false;
        } else {
            return x.contains_address(p);
        }
    }

    void eval_to_prec(mpf_class& dst, std::uint64_t final_prec) const {
        (void)final_prec;
        if constexpr (std::same_as<X, mpf_class>) {
            Op::apply(dst, x);
        } else {
            x.eval_to_prec(dst, final_prec);
            Op::apply(dst, dst);
        }
    }

    void eval_to_mpz(mpz_class& dst) const
        requires (std::same_as<result_type, mpz_class>) {
        if constexpr (std::same_as<X, mpz_class>) {
            Op::apply(dst, x);
        } else {
            x.eval_to_mpz(dst);
            Op::apply(dst, dst);
        }
    }

    void eval_to_mpq(mpq_class& dst) const
        requires (std::same_as<result_type, mpq_class>) {
        if constexpr (std::same_as<X, mpq_class>) {
            Op::apply(dst, x);
        } else {
            x.eval_to_mpq(dst);
            Op::apply(dst, dst);
        }
    }
};

template<class Op, class L, class R>
struct [[nodiscard]] binary_expr : expr_base<binary_expr<Op, L, R>> {
    using result_type = gmpxx_mkII_detail::result_type_t<L, R>;

    using lhs_storage = std::conditional_t<
        scalar_operand<L>,
        gmpxx_mkII_detail::operand_storage_t<L>,
        L const&>;
    using rhs_storage = std::conditional_t<
        scalar_operand<R>,
        gmpxx_mkII_detail::operand_storage_t<R>,
        R const&>;

    lhs_storage lhs;
    rhs_storage rhs;

    binary_expr(L const& lhs_, R const& rhs_) : lhs(lhs_), rhs(rhs_) {}

    [[nodiscard]] std::uint64_t suggested_prec_impl() const {
        if constexpr (gmpxx_mkII_detail::has_mpf_precision_v<L> &&
                      gmpxx_mkII_detail::has_mpf_precision_v<R>) {
            return std::max(gmpxx_mkII_detail::prec_of(lhs),
                            gmpxx_mkII_detail::prec_of(rhs));
        } else if constexpr (gmpxx_mkII_detail::has_mpf_precision_v<L>) {
            return gmpxx_mkII_detail::prec_of(lhs);
        } else if constexpr (gmpxx_mkII_detail::has_mpf_precision_v<R>) {
            return gmpxx_mkII_detail::prec_of(rhs);
        } else {
            return gmpxx_mkII_detail::thread_default_prec();
        }
    }

    [[nodiscard]] bool contains_address(mpf_class const* p) const {
        bool l_hit;
        if constexpr (scalar_operand<L>) {
            l_hit = false;
        } else if constexpr (std::same_as<L, mpf_class>) {
            l_hit = &lhs == p;
        } else if constexpr (std::same_as<L, mpz_class> ||
                             std::same_as<L, mpq_class>) {
            l_hit = false;
        } else {
            l_hit = lhs.contains_address(p);
        }
        if (l_hit) {
            return true;
        }
        if constexpr (scalar_operand<R>) {
            return false;
        } else if constexpr (std::same_as<R, mpf_class>) {
            return &rhs == p;
        } else if constexpr (std::same_as<R, mpz_class> ||
                             std::same_as<R, mpq_class>) {
            return false;
        } else {
            return rhs.contains_address(p);
        }
    }

    [[nodiscard]] bool contains_address(mpz_class const* p) const {
        bool l_hit;
        if constexpr (scalar_operand<L> || std::same_as<L, mpf_class> ||
                      std::same_as<L, mpq_class>) {
            l_hit = false;
        } else if constexpr (std::same_as<L, mpz_class>) {
            l_hit = &lhs == p;
        } else {
            l_hit = lhs.contains_address(p);
        }
        if (l_hit) {
            return true;
        }
        if constexpr (scalar_operand<R> || std::same_as<R, mpf_class> ||
                      std::same_as<R, mpq_class>) {
            return false;
        } else if constexpr (std::same_as<R, mpz_class>) {
            return &rhs == p;
        } else {
            return rhs.contains_address(p);
        }
    }

    [[nodiscard]] bool contains_address(mpq_class const* p) const {
        bool l_hit;
        if constexpr (scalar_operand<L> || std::same_as<L, mpf_class> ||
                      std::same_as<L, mpz_class>) {
            l_hit = false;
        } else if constexpr (std::same_as<L, mpq_class>) {
            l_hit = &lhs == p;
        } else {
            l_hit = lhs.contains_address(p);
        }
        if (l_hit) {
            return true;
        }
        if constexpr (scalar_operand<R> || std::same_as<R, mpf_class> ||
                      std::same_as<R, mpz_class>) {
            return false;
        } else if constexpr (std::same_as<R, mpq_class>) {
            return &rhs == p;
        } else {
            return rhs.contains_address(p);
        }
    }

    void eval_to_prec(mpf_class& dst, std::uint64_t final_prec) const {
        constexpr bool l_leaf = std::same_as<L, mpf_class>;
        constexpr bool r_leaf = std::same_as<R, mpf_class>;
        constexpr bool l_z_leaf = std::same_as<L, mpz_class>;
        constexpr bool r_z_leaf = std::same_as<R, mpz_class>;
        constexpr bool l_q_leaf = std::same_as<L, mpq_class>;
        constexpr bool r_q_leaf = std::same_as<R, mpq_class>;
        constexpr bool l_scalar = scalar_operand<L>;
        constexpr bool r_scalar = scalar_operand<R>;

        if constexpr ((l_leaf || l_z_leaf || l_q_leaf || l_scalar) &&
                      (r_leaf || r_z_leaf || r_q_leaf || r_scalar)) {
            Op::apply(dst, lhs, rhs);
        } else if constexpr (!l_leaf && !l_z_leaf && !l_q_leaf && !l_scalar &&
                             (r_leaf || r_z_leaf || r_q_leaf || r_scalar)) {
            lhs.eval_to_prec(dst, final_prec);
            Op::apply(dst, dst, rhs);
        } else if constexpr ((l_leaf || l_z_leaf || l_q_leaf || l_scalar) &&
                             !r_leaf && !r_z_leaf && !r_q_leaf && !r_scalar) {
            rhs.eval_to_prec(dst, final_prec);
            Op::apply(dst, lhs, dst);
        } else {
            mpf_class tmp(gmpxx_mkII_detail::checked_mp_bitcnt(final_prec));
            rhs.eval_to_prec(tmp, final_prec);
            lhs.eval_to_prec(dst, final_prec);
            Op::apply(dst, dst, tmp);
        }
    }

    void eval_to_mpz(mpz_class& dst) const
        requires (std::same_as<result_type, mpz_class>) {
        constexpr bool l_value = std::same_as<L, mpz_class> || scalar_operand<L>;
        constexpr bool r_value = std::same_as<R, mpz_class> || scalar_operand<R>;
        if constexpr (l_value && r_value) {
            Op::apply(dst, lhs, rhs);
        } else if constexpr (!l_value && r_value) {
            lhs.eval_to_mpz(dst);
            Op::apply(dst, dst, rhs);
        } else if constexpr (l_value && !r_value) {
            rhs.eval_to_mpz(dst);
            Op::apply(dst, lhs, dst);
        } else {
            mpz_class tmp;
            rhs.eval_to_mpz(tmp);
            lhs.eval_to_mpz(dst);
            Op::apply(dst, dst, tmp);
        }
    }

    void eval_to_mpq(mpq_class& dst) const
        requires (std::same_as<result_type, mpq_class>) {
        constexpr bool l_value =
            std::same_as<L, mpq_class> || std::same_as<L, mpz_class> ||
            scalar_operand<L>;
        constexpr bool r_value =
            std::same_as<R, mpq_class> || std::same_as<R, mpz_class> ||
            scalar_operand<R>;
        if constexpr (l_value && r_value) {
            Op::apply(dst, lhs, rhs);
        } else if constexpr (!l_value && r_value) {
            lhs.eval_to_mpq(dst);
            Op::apply(dst, dst, rhs);
        } else if constexpr (l_value && !r_value) {
            rhs.eval_to_mpq(dst);
            Op::apply(dst, lhs, dst);
        } else {
            mpq_class tmp;
            rhs.eval_to_mpq(tmp);
            lhs.eval_to_mpq(dst);
            Op::apply(dst, dst, tmp);
        }
    }
};

namespace gmpxx_mkII_detail {

inline void note_mpz_addmul_fused() noexcept {
#if defined(GMPXX_MKII_TEST_FUSION_COUNTERS)
    test_mpz_addmul_fused_count.fetch_add(1, std::memory_order_relaxed);
#endif
}

inline void note_mpz_submul_fused() noexcept {
#if defined(GMPXX_MKII_TEST_FUSION_COUNTERS)
    test_mpz_submul_fused_count.fetch_add(1, std::memory_order_relaxed);
#endif
}

inline void note_mpz_addmul_ui_fused() noexcept {
#if defined(GMPXX_MKII_TEST_FUSION_COUNTERS)
    test_mpz_addmul_ui_fused_count.fetch_add(1, std::memory_order_relaxed);
#endif
}

inline void note_mpz_submul_ui_fused() noexcept {
#if defined(GMPXX_MKII_TEST_FUSION_COUNTERS)
    test_mpz_submul_ui_fused_count.fetch_add(1, std::memory_order_relaxed);
#endif
}

template<bool Add>
inline void mpz_addmul_apply_unsigned(
    mpz_class& dst, mpz_class const& lhs, std::uint64_t rhs) {
    if (fits_in_ulong(rhs)) {
        if constexpr (Add) {
            note_mpz_addmul_ui_fused();
            mpz_addmul_ui(dst.get_mpz_t(), lhs.get_mpz_t(),
                          static_cast<unsigned long>(rhs));
        } else {
            note_mpz_submul_ui_fused();
            mpz_submul_ui(dst.get_mpz_t(), lhs.get_mpz_t(),
                          static_cast<unsigned long>(rhs));
        }
    } else {
        mpz_class tmp(rhs);
        if constexpr (Add) {
            note_mpz_addmul_fused();
            mpz_addmul(dst.get_mpz_t(), lhs.get_mpz_t(), tmp.get_mpz_t());
        } else {
            note_mpz_submul_fused();
            mpz_submul(dst.get_mpz_t(), lhs.get_mpz_t(), tmp.get_mpz_t());
        }
    }
}

template<bool Add>
inline void mpz_addmul_apply_signed(
    mpz_class& dst, mpz_class const& lhs, std::int64_t rhs) {
    if (rhs >= 0) {
        mpz_addmul_apply_unsigned<Add>(
            dst, lhs, static_cast<std::uint64_t>(rhs));
    } else {
        mpz_addmul_apply_unsigned<!Add>(dst, lhs, safe_negate(rhs));
    }
}

template<bool Add, class Scalar>
inline void mpz_addmul_apply_scalar(
    mpz_class& dst, mpz_class const& lhs, Scalar rhs) {
    using scalar_type = scalar_normalize_t<Scalar>;
    static_assert(std::same_as<scalar_type, std::int64_t> ||
                  std::same_as<scalar_type, std::uint64_t>);
    if constexpr (std::same_as<scalar_type, std::int64_t>) {
        mpz_addmul_apply_signed<Add>(
            dst, lhs, static_cast<std::int64_t>(rhs));
    } else {
        mpz_addmul_apply_unsigned<Add>(
            dst, lhs, static_cast<std::uint64_t>(rhs));
    }
}

template<bool Add>
inline void mpz_addmul_apply_pair(
    mpz_class& dst, mpz_class const& lhs, mpz_class const& rhs) {
    if constexpr (Add) {
        note_mpz_addmul_fused();
        mpz_addmul(dst.get_mpz_t(), lhs.get_mpz_t(), rhs.get_mpz_t());
    } else {
        note_mpz_submul_fused();
        mpz_submul(dst.get_mpz_t(), lhs.get_mpz_t(), rhs.get_mpz_t());
    }
}

template<bool Add, class L, class R>
inline void mpz_addmul_fused_apply_impl(
    mpz_class& dst, binary_expr<mul_op, L, R> const& expr) {
    if constexpr (std::same_as<L, mpz_class> && std::same_as<R, mpz_class>) {
        mpz_addmul_apply_pair<Add>(dst, expr.lhs, expr.rhs);
    } else if constexpr (std::same_as<L, mpz_class> &&
                         is_integral_scalar_leaf_v<R>) {
        mpz_addmul_apply_scalar<Add>(dst, expr.lhs, expr.rhs);
    } else {
        static_assert(is_integral_scalar_leaf_v<L> &&
                      std::same_as<R, mpz_class>);
        mpz_addmul_apply_scalar<Add>(dst, expr.rhs, expr.lhs);
    }
}

template<class Expr>
inline void addmul_fused_apply(mpz_class& dst, Expr const& expr) {
    static_assert(is_mpz_addmul_fusable_v<Expr>);
    mpz_addmul_fused_apply_impl<true>(dst, expr);
}

template<class Expr>
inline void submul_fused_apply(mpz_class& dst, Expr const& expr) {
    static_assert(is_mpz_addmul_fusable_v<Expr>);
    mpz_addmul_fused_apply_impl<false>(dst, expr);
}

}  // namespace gmpxx_mkII_detail

template<class Derived>
[[nodiscard]] auto expr_base<Derived>::eval() const {
    using result_type = typename Derived::result_type;
    return result_type(self());
}

template<class Derived>
void expr_base<Derived>::eval_to(mpz_class& dst) const {
    self().eval_to_mpz(dst);
}

template<class Derived>
void expr_base<Derived>::eval_to(mpq_class& dst) const {
    self().eval_to_mpq(dst);
}

namespace gmpxx_mkII_detail {

inline int normalize_cmp_result(int value) noexcept {
    return (value > 0) - (value < 0);
}

inline mpq_class to_mpq_for_cmp(mpq_class const& value) {
    return value;
}

inline mpq_class to_mpq_for_cmp(mpz_class const& value) {
    return mpq_class(value);
}

inline mpq_class to_mpq_for_cmp(mpf_class const& value) {
    mpq_class result;
    mpq_set_f(result.get_mpq_t(), value.get_mpf_t());
    result.canonicalize();
    return result;
}

inline mpq_class to_mpq_for_cmp(std::int64_t value) {
    return mpq_class(value);
}

inline mpq_class to_mpq_for_cmp(std::uint64_t value) {
    mpz_class z(value);
    return mpq_class(z);
}

inline mpq_class to_mpq_for_cmp(double value) {
    mpf_class tmp(value, static_cast<mp_bitcnt_t>(DBL_MANT_DIG));
    return to_mpq_for_cmp(tmp);
}

template<class T>
auto materialize_for_cmp(T const& value) {
    using clean = std::remove_cvref_t<T>;
    if constexpr (is_gmpxx_expr_v<clean>) {
        return value.eval();
    } else if constexpr (scalar_operand<clean>) {
        using normalized = scalar_normalize_t<clean>;
        return static_cast<normalized>(value);
    } else {
        return value;
    }
}

template<class L, class R>
int cmp_values(L const& lhs, R const& rhs) {
    mpq_class lq = to_mpq_for_cmp(lhs);
    mpq_class rq = to_mpq_for_cmp(rhs);
    return normalize_cmp_result(mpq_cmp(lq.get_mpq_t(), rq.get_mpq_t()));
}

}  // namespace gmpxx_mkII_detail

template<class L, class R>
    requires comparison_pair<L, R>
int cmp(L const& lhs, R const& rhs) {
    auto lhs_value = gmpxx_mkII_detail::materialize_for_cmp(lhs);
    auto rhs_value = gmpxx_mkII_detail::materialize_for_cmp(rhs);
    return gmpxx_mkII_detail::cmp_values(lhs_value, rhs_value);
}

template<class L, class R>
    requires comparison_pair<L, R>
bool operator==(L const& lhs, R const& rhs) {
    return cmp(lhs, rhs) == 0;
}

template<class L, class R>
    requires comparison_pair<L, R>
bool operator!=(L const& lhs, R const& rhs) {
    return cmp(lhs, rhs) != 0;
}

template<class L, class R>
    requires comparison_pair<L, R>
bool operator<(L const& lhs, R const& rhs) {
    return cmp(lhs, rhs) < 0;
}

template<class L, class R>
    requires comparison_pair<L, R>
bool operator<=(L const& lhs, R const& rhs) {
    return cmp(lhs, rhs) <= 0;
}

template<class L, class R>
    requires comparison_pair<L, R>
bool operator>(L const& lhs, R const& rhs) {
    return cmp(lhs, rhs) > 0;
}

template<class L, class R>
    requires comparison_pair<L, R>
bool operator>=(L const& lhs, R const& rhs) {
    return cmp(lhs, rhs) >= 0;
}

inline std::ostream& operator<<(std::ostream& os, mpz_class const& value) {
    try {
        os << value.get_str(gmpxx_mkII_detail::stream_integer_base(os));
    } catch (...) {
        os.setstate(std::ios_base::badbit);
    }
    return os;
}

inline std::ostream& operator<<(std::ostream& os, mpq_class const& value) {
    try {
        os << value.get_str(gmpxx_mkII_detail::stream_integer_base(os));
    } catch (...) {
        os.setstate(std::ios_base::badbit);
    }
    return os;
}

inline std::ostream& operator<<(std::ostream& os, mpf_class const& value) {
    try {
        std::string s = gmpxx_mkII_detail::format_mpf(value, os);
        if (s.empty()) {
            os.setstate(std::ios_base::badbit);
        } else {
            os << s;
        }
    } catch (...) {
        os.setstate(std::ios_base::badbit);
    }
    return os;
}

template<gmpxx_expr Expr>
inline std::ostream& operator<<(std::ostream& os, Expr const& expr) {
    auto value = expr.eval();
    os << value;
    return os;
}

inline std::istream& operator>>(std::istream& is, mpz_class& value) {
    std::istream::sentry sentry(is);
    if (!sentry) {
        return is;
    }

    std::string token;
    if (!(is >> token)) {
        return is;
    }

    mpz_class tmp;
    if (tmp.set_str(token, gmpxx_mkII_detail::stream_input_base(is)) == 0) {
        value.swap(tmp);
    } else {
        is.setstate(std::ios_base::failbit);
    }
    return is;
}

inline std::istream& operator>>(std::istream& is, mpq_class& value) {
    std::istream::sentry sentry(is);
    if (!sentry) {
        return is;
    }

    std::string token;
    if (!(is >> token)) {
        return is;
    }

    mpq_class tmp;
    if (tmp.set_str(token, gmpxx_mkII_detail::stream_input_base(is)) == 0) {
        value.swap(tmp);
    } else {
        is.setstate(std::ios_base::failbit);
    }
    return is;
}

inline std::istream& operator>>(std::istream& is, mpf_class& value) {
    std::istream::sentry sentry(is);
    if (!sentry) {
        return is;
    }

    std::string token;
    if (!(is >> token)) {
        return is;
    }

    int base = gmpxx_mkII_detail::stream_input_base(is);
    if (base == 0) {
        base = 10;
    }

    mpf_class tmp(value.get_prec());
    if (tmp.set_str(token, base) == 0) {
        value.swap(tmp);
    } else {
        is.setstate(std::ios_base::failbit);
    }
    return is;
}

template<phase0_operand L, phase0_operand R>
[[nodiscard]] inline auto operator+(L const& l, R const& r) {
    return binary_expr<add_op, std::remove_cvref_t<L>, std::remove_cvref_t<R>>{l, r};
}

template<phase1_operand L, scalar_operand R>
    requires (!scalar_operand<L>)
[[nodiscard]] inline auto operator+(L const& l, R const& r) {
    using NR = scalar_normalize_t<R>;
    return binary_expr<add_op, std::remove_cvref_t<L>, NR>{
        l, static_cast<NR>(r)};
}

template<scalar_operand L, phase1_operand R>
    requires (!scalar_operand<R>)
[[nodiscard]] inline auto operator+(L const& l, R const& r) {
    using NL = scalar_normalize_t<L>;
    return binary_expr<add_op, NL, std::remove_cvref_t<R>>{
        static_cast<NL>(l), r};
}

template<phase2_operand L, phase2_operand R>
    requires (!(phase1_operand<L> && phase1_operand<R>) &&
              !(scalar_operand<L> && scalar_operand<R>))
[[nodiscard]] inline auto operator+(L const& l, R const& r) {
    using NL = gmpxx_mkII_detail::operand_storage_t<L>;
    using NR = gmpxx_mkII_detail::operand_storage_t<R>;
    if constexpr (scalar_operand<L> && !scalar_operand<R>) {
        return binary_expr<add_op, NL, std::remove_cvref_t<R>>{
            static_cast<NL>(l), r};
    } else if constexpr (!scalar_operand<L> && scalar_operand<R>) {
        return binary_expr<add_op, std::remove_cvref_t<L>, NR>{
            l, static_cast<NR>(r)};
    } else {
        return binary_expr<add_op, std::remove_cvref_t<L>, std::remove_cvref_t<R>>{
            l, r};
    }
}

template<phase0_operand L, phase0_operand R>
[[nodiscard]] inline auto operator-(L const& l, R const& r) {
    return binary_expr<sub_op, std::remove_cvref_t<L>, std::remove_cvref_t<R>>{l, r};
}

template<phase1_operand L, scalar_operand R>
    requires (!scalar_operand<L>)
[[nodiscard]] inline auto operator-(L const& l, R const& r) {
    using NR = scalar_normalize_t<R>;
    return binary_expr<sub_op, std::remove_cvref_t<L>, NR>{
        l, static_cast<NR>(r)};
}

template<scalar_operand L, phase1_operand R>
    requires (!scalar_operand<R>)
[[nodiscard]] inline auto operator-(L const& l, R const& r) {
    using NL = scalar_normalize_t<L>;
    return binary_expr<sub_op, NL, std::remove_cvref_t<R>>{
        static_cast<NL>(l), r};
}

template<phase2_operand L, phase2_operand R>
    requires (!(phase1_operand<L> && phase1_operand<R>) &&
              !(scalar_operand<L> && scalar_operand<R>))
[[nodiscard]] inline auto operator-(L const& l, R const& r) {
    using NL = gmpxx_mkII_detail::operand_storage_t<L>;
    using NR = gmpxx_mkII_detail::operand_storage_t<R>;
    if constexpr (scalar_operand<L> && !scalar_operand<R>) {
        return binary_expr<sub_op, NL, std::remove_cvref_t<R>>{
            static_cast<NL>(l), r};
    } else if constexpr (!scalar_operand<L> && scalar_operand<R>) {
        return binary_expr<sub_op, std::remove_cvref_t<L>, NR>{
            l, static_cast<NR>(r)};
    } else {
        return binary_expr<sub_op, std::remove_cvref_t<L>, std::remove_cvref_t<R>>{
            l, r};
    }
}

template<phase0_operand L, phase0_operand R>
[[nodiscard]] inline auto operator*(L const& l, R const& r) {
    return binary_expr<mul_op, std::remove_cvref_t<L>, std::remove_cvref_t<R>>{l, r};
}

