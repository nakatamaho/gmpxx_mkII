namespace literals {

inline mpz_class operator""_mpz(unsigned long long value) {
    return mpz_class(static_cast<std::uint64_t>(value));
}

inline mpz_class operator""_mpz(char const* text) {
    return mpz_class(text, 10);
}

inline mpz_class operator""_mpz(char const* text, std::size_t) {
    return mpz_class(text);
}

inline mpq_class operator""_mpq(unsigned long long value) {
    return mpq_class(mpz_class(static_cast<std::uint64_t>(value)));
}

inline mpq_class operator""_mpq(char const* text) {
    return mpq_class(text, 10);
}

inline mpq_class operator""_mpq(char const* text, std::size_t) {
    return mpq_class(text);
}

inline mpf_class operator""_mpf(char const* text) {
    return mpf_class(text, gmpxx_detail::checked_mp_bitcnt(
                               gmpxx_detail::thread_default_prec()),
                     10);
}

inline mpf_class operator""_mpf(char const* text, std::size_t) {
    return mpf_class(text);
}

}  // namespace literals

}  // namespace gmpxx
