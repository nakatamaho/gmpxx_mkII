inline mpf_class& mpf_class::operator+=(mpf_class const& rhs) {
    add_op::apply(*this, *this, rhs);
    return *this;
}

inline mpf_class& mpf_class::operator-=(mpf_class const& rhs) {
    sub_op::apply(*this, *this, rhs);
    return *this;
}

inline mpf_class& mpf_class::operator*=(mpf_class const& rhs) {
    mul_op::apply(*this, *this, rhs);
    return *this;
}

inline mpf_class& mpf_class::operator/=(mpf_class const& rhs) {
    div_op::apply(*this, *this, rhs);
    return *this;
}

template<gmpxx_expr Expr>
    requires (std::same_as<typename Expr::result_type, mpf_class>)
inline mpf_class& mpf_class::operator+=(Expr const& expr) {
    mpf_class tmp(this->get_prec());
    expr.eval_to_prec(tmp, static_cast<std::uint64_t>(this->get_prec()));
    add_op::apply(*this, *this, tmp);
    return *this;
}

template<gmpxx_expr Expr>
    requires (std::same_as<typename Expr::result_type, mpf_class>)
inline mpf_class& mpf_class::operator-=(Expr const& expr) {
    mpf_class tmp(this->get_prec());
    expr.eval_to_prec(tmp, static_cast<std::uint64_t>(this->get_prec()));
    sub_op::apply(*this, *this, tmp);
    return *this;
}

template<gmpxx_expr Expr>
    requires (std::same_as<typename Expr::result_type, mpf_class>)
inline mpf_class& mpf_class::operator*=(Expr const& expr) {
    mpf_class tmp(this->get_prec());
    expr.eval_to_prec(tmp, static_cast<std::uint64_t>(this->get_prec()));
    mul_op::apply(*this, *this, tmp);
    return *this;
}

template<gmpxx_expr Expr>
    requires (std::same_as<typename Expr::result_type, mpf_class>)
inline mpf_class& mpf_class::operator/=(Expr const& expr) {
    mpf_class tmp(this->get_prec());
    expr.eval_to_prec(tmp, static_cast<std::uint64_t>(this->get_prec()));
    div_op::apply(*this, *this, tmp);
    return *this;
}

template<scalar_operand T>
inline mpf_class& mpf_class::operator+=(T const& rhs) {
    using N = scalar_normalize_t<T>;
    add_op::apply(*this, *this, static_cast<N>(rhs));
    return *this;
}

template<scalar_operand T>
inline mpf_class& mpf_class::operator-=(T const& rhs) {
    using N = scalar_normalize_t<T>;
    sub_op::apply(*this, *this, static_cast<N>(rhs));
    return *this;
}

template<scalar_operand T>
inline mpf_class& mpf_class::operator*=(T const& rhs) {
    using N = scalar_normalize_t<T>;
    mul_op::apply(*this, *this, static_cast<N>(rhs));
    return *this;
}

template<scalar_operand T>
inline mpf_class& mpf_class::operator/=(T const& rhs) {
    using N = scalar_normalize_t<T>;
    div_op::apply(*this, *this, static_cast<N>(rhs));
    return *this;
}

inline mpz_class& mpz_class::operator+=(mpz_class const& rhs) {
    mpz_add(value, value, rhs.value);
    return *this;
}

inline mpz_class& mpz_class::operator-=(mpz_class const& rhs) {
    mpz_sub(value, value, rhs.value);
    return *this;
}

inline mpz_class& mpz_class::operator*=(mpz_class const& rhs) {
    mpz_mul(value, value, rhs.value);
    return *this;
}

inline mpz_class& mpz_class::operator/=(mpz_class const& rhs) {
    mpz_tdiv_q(value, value, rhs.value);
    return *this;
}

inline mpz_class& mpz_class::operator%=(mpz_class const& rhs) {
    mpz_tdiv_r(value, value, rhs.value);
    return *this;
}

template<gmpxx_expr Expr>
    requires (std::same_as<typename Expr::result_type, mpz_class>)
inline mpz_class& mpz_class::operator+=(Expr const& expr) {
    if constexpr (gmpxx_mkII_detail::is_mpz_addmul_fusable_v<Expr>) {
        gmpxx_mkII_detail::addmul_fused_apply(*this, expr);
    } else {
        mpz_class tmp;
        expr.eval_to(tmp);
        add_op::apply(*this, *this, tmp);
    }
    return *this;
}

template<gmpxx_expr Expr>
    requires (std::same_as<typename Expr::result_type, mpz_class>)
inline mpz_class& mpz_class::operator-=(Expr const& expr) {
    if constexpr (gmpxx_mkII_detail::is_mpz_addmul_fusable_v<Expr>) {
        gmpxx_mkII_detail::submul_fused_apply(*this, expr);
    } else {
        mpz_class tmp;
        expr.eval_to(tmp);
        sub_op::apply(*this, *this, tmp);
    }
    return *this;
}

template<gmpxx_expr Expr>
    requires (std::same_as<typename Expr::result_type, mpz_class>)
inline mpz_class& mpz_class::operator*=(Expr const& expr) {
    mpz_class tmp;
    expr.eval_to(tmp);
    mul_op::apply(*this, *this, tmp);
    return *this;
}

template<gmpxx_expr Expr>
    requires (std::same_as<typename Expr::result_type, mpz_class>)
inline mpz_class& mpz_class::operator/=(Expr const& expr) {
    mpz_class tmp;
    expr.eval_to(tmp);
    div_op::apply(*this, *this, tmp);
    return *this;
}

template<scalar_operand T>
inline mpz_class& mpz_class::operator+=(T const& rhs) {
    using N = scalar_normalize_t<T>;
    add_op::apply(*this, *this, static_cast<N>(rhs));
    return *this;
}

template<scalar_operand T>
inline mpz_class& mpz_class::operator-=(T const& rhs) {
    using N = scalar_normalize_t<T>;
    sub_op::apply(*this, *this, static_cast<N>(rhs));
    return *this;
}

template<scalar_operand T>
inline mpz_class& mpz_class::operator*=(T const& rhs) {
    using N = scalar_normalize_t<T>;
    mul_op::apply(*this, *this, static_cast<N>(rhs));
    return *this;
}

template<scalar_operand T>
inline mpz_class& mpz_class::operator/=(T const& rhs) {
    using N = scalar_normalize_t<T>;
    div_op::apply(*this, *this, static_cast<N>(rhs));
    return *this;
}

inline mpq_class& mpq_class::operator+=(mpq_class const& rhs) {
    mpq_add(value, value, rhs.value);
    return *this;
}

inline mpq_class& mpq_class::operator-=(mpq_class const& rhs) {
    mpq_sub(value, value, rhs.value);
    return *this;
}

inline mpq_class& mpq_class::operator*=(mpq_class const& rhs) {
    mpq_mul(value, value, rhs.value);
    return *this;
}

inline mpq_class& mpq_class::operator/=(mpq_class const& rhs) {
    mpq_div(value, value, rhs.value);
    return *this;
}

template<gmpxx_expr Expr>
    requires (std::same_as<typename Expr::result_type, mpq_class>)
inline mpq_class& mpq_class::operator+=(Expr const& expr) {
    mpq_class tmp;
    expr.eval_to(tmp);
    add_op::apply(*this, *this, tmp);
    return *this;
}

