        static_cast<NL>(l), r};
}

template<phase2_operand L, phase2_operand R>
    requires (!(phase1_operand<L> && phase1_operand<R>) &&
              !(scalar_operand<L> && scalar_operand<R>))
[[nodiscard]] inline auto operator-(L const& l, R const& r) {
    using NL = gmpxx_mkII_detail::operand_storage_t<L>;
    using NR = gmpxx_mkII_detail::operand_storage_t<R>;
    if constexpr (scalar_operand<L> && !scalar_operand<R>) {
        return binary_expr<sub_op, NL, std::remove_cvref_t<R>>{
            static_cast<NL>(l), r};
    } else if constexpr (!scalar_operand<L> && scalar_operand<R>) {
        return binary_expr<sub_op, std::remove_cvref_t<L>, NR>{
            l, static_cast<NR>(r)};
    } else {
        return binary_expr<sub_op, std::remove_cvref_t<L>, std::remove_cvref_t<R>>{
            l, r};
    }
}

template<phase0_operand L, phase0_operand R>
[[nodiscard]] inline auto operator*(L const& l, R const& r) {
    return binary_expr<mul_op, std::remove_cvref_t<L>, std::remove_cvref_t<R>>{l, r};
}

