                          mpf_class const& rhs) {
    if (lhs >= 0) {
        apply(dst, static_cast<std::uint64_t>(lhs), rhs);
    } else {
        apply(dst, gmpxx_mkII_detail::safe_negate(lhs), rhs);
        mpf_neg(dst.get_mpf_t(), dst.get_mpf_t());
