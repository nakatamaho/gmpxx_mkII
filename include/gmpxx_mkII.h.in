namespace gmpxx_mkII_detail {

inline std::uint64_t prec_of(mpf_class const& x) {
    return static_cast<std::uint64_t>(x.get_prec());
}

template<class Op, class X>
inline std::uint64_t prec_of(unary_expr<Op, X> const& e) {
    return e.suggested_prec();
}

template<class Op, class L, class R>
inline std::uint64_t prec_of(binary_expr<Op, L, R> const& e) {
    return e.suggested_prec();
}

}  // namespace gmpxx_mkII_detail

template<class Op, class X>
struct [[nodiscard]] unary_expr : expr_base<unary_expr<Op, X>> {
    using result_type = gmpxx_mkII_detail::result_or_self_t<X>;

    X const& x;

    explicit unary_expr(X const& x_) : x(x_) {}

    [[nodiscard]] X const& operand() const noexcept {
        return x;
    }

    [[nodiscard]] std::uint64_t suggested_prec_impl() const {
        if constexpr (gmpxx_mkII_detail::has_mpf_precision_v<X>) {
            return gmpxx_mkII_detail::prec_of(x);
        } else {
            return gmpxx_mkII_detail::thread_default_prec();
        }
    }

    [[nodiscard]] bool contains_address(mpf_class const* p) const {
        if constexpr (std::same_as<X, mpf_class>) {
            return &x == p;
        } else if constexpr (scalar_operand<X> || mpz_operand<X> || mpq_operand<X>) {
            return false;
        } else {
            return x.contains_address(p);
        }
    }

    [[nodiscard]] bool contains_address(mpz_class const* p) const {
        if constexpr (std::same_as<X, mpz_class>) {
            return &x == p;
        } else if constexpr (scalar_operand<X> || std::same_as<X, mpf_class> ||
                             std::same_as<X, mpq_class>) {
            return false;
        } else {
            return x.contains_address(p);
        }
    }

    [[nodiscard]] bool contains_address(mpq_class const* p) const {
        if constexpr (std::same_as<X, mpq_class>) {
            return &x == p;
        } else if constexpr (scalar_operand<X> || std::same_as<X, mpf_class> ||
                             std::same_as<X, mpz_class>) {
            return false;
        } else {
            return x.contains_address(p);
        }
    }

    void eval_to_prec(mpf_class& dst, std::uint64_t final_prec) const {
        (void)final_prec;
        if constexpr (std::same_as<X, mpf_class>) {
            Op::apply(dst, x);
        } else {
            x.eval_to_prec(dst, final_prec);
            Op::apply(dst, dst);
        }
    }

    void eval_to_mpz(mpz_class& dst) const
        requires (std::same_as<result_type, mpz_class>) {
        if constexpr (std::same_as<X, mpz_class>) {
            Op::apply(dst, x);
        } else {
            x.eval_to_mpz(dst);
            Op::apply(dst, dst);
        }
    }

    void eval_to_mpq(mpq_class& dst) const
        requires (std::same_as<result_type, mpq_class>) {
        if constexpr (std::same_as<X, mpq_class>) {
            Op::apply(dst, x);
        } else {
            x.eval_to_mpq(dst);
            Op::apply(dst, dst);
        }
    }
};

template<class Op, class L, class R>
struct [[nodiscard]] binary_expr : expr_base<binary_expr<Op, L, R>> {
    using result_type = gmpxx_mkII_detail::result_type_t<L, R>;

    using lhs_storage = std::conditional_t<
        scalar_operand<L>,
        gmpxx_mkII_detail::operand_storage_t<L>,
        L const&>;
    using rhs_storage = std::conditional_t<
        scalar_operand<R>,
        gmpxx_mkII_detail::operand_storage_t<R>,
        R const&>;

    lhs_storage lhs;
    rhs_storage rhs;

    binary_expr(L const& lhs_, R const& rhs_) : lhs(lhs_), rhs(rhs_) {}

    [[nodiscard]] std::uint64_t suggested_prec_impl() const {
        if constexpr (gmpxx_mkII_detail::has_mpf_precision_v<L> &&
                      gmpxx_mkII_detail::has_mpf_precision_v<R>) {
            return std::max(gmpxx_mkII_detail::prec_of(lhs),
                            gmpxx_mkII_detail::prec_of(rhs));
        } else if constexpr (gmpxx_mkII_detail::has_mpf_precision_v<L>) {
            return gmpxx_mkII_detail::prec_of(lhs);
        } else if constexpr (gmpxx_mkII_detail::has_mpf_precision_v<R>) {
            return gmpxx_mkII_detail::prec_of(rhs);
        } else {
            return gmpxx_mkII_detail::thread_default_prec();
        }
    }

    [[nodiscard]] bool contains_address(mpf_class const* p) const {
        bool l_hit;
        if constexpr (scalar_operand<L>) {
            l_hit = false;
        } else if constexpr (std::same_as<L, mpf_class>) {
            l_hit = &lhs == p;
        } else if constexpr (std::same_as<L, mpz_class> ||
                             std::same_as<L, mpq_class>) {
            l_hit = false;
        } else {
            l_hit = lhs.contains_address(p);
        }
        if (l_hit) {
            return true;
        }
        if constexpr (scalar_operand<R>) {
            return false;
        } else if constexpr (std::same_as<R, mpf_class>) {
            return &rhs == p;
        } else if constexpr (std::same_as<R, mpz_class> ||
                             std::same_as<R, mpq_class>) {
            return false;
        } else {
            return rhs.contains_address(p);
        }
    }

    [[nodiscard]] bool contains_address(mpz_class const* p) const {
        bool l_hit;
        if constexpr (scalar_operand<L> || std::same_as<L, mpf_class> ||
                      std::same_as<L, mpq_class>) {
            l_hit = false;
        } else if constexpr (std::same_as<L, mpz_class>) {
            l_hit = &lhs == p;
        } else {
            l_hit = lhs.contains_address(p);
        }
        if (l_hit) {
            return true;
        }
        if constexpr (scalar_operand<R> || std::same_as<R, mpf_class> ||
                      std::same_as<R, mpq_class>) {
            return false;
        } else if constexpr (std::same_as<R, mpz_class>) {
            return &rhs == p;
        } else {
            return rhs.contains_address(p);
        }
    }

    [[nodiscard]] bool contains_address(mpq_class const* p) const {
        bool l_hit;
        if constexpr (scalar_operand<L> || std::same_as<L, mpf_class> ||
                      std::same_as<L, mpz_class>) {
            l_hit = false;
        } else if constexpr (std::same_as<L, mpq_class>) {
            l_hit = &lhs == p;
        } else {
            l_hit = lhs.contains_address(p);
        }
        if (l_hit) {
            return true;
        }
        if constexpr (scalar_operand<R> || std::same_as<R, mpf_class> ||
                      std::same_as<R, mpz_class>) {
            return false;
        } else if constexpr (std::same_as<R, mpq_class>) {
            return &rhs == p;
        } else {
            return rhs.contains_address(p);
        }
    }

    void eval_to_prec(mpf_class& dst, std::uint64_t final_prec) const {
        constexpr bool l_leaf = std::same_as<L, mpf_class>;
        constexpr bool r_leaf = std::same_as<R, mpf_class>;
        constexpr bool l_z_leaf = std::same_as<L, mpz_class>;
        constexpr bool r_z_leaf = std::same_as<R, mpz_class>;
        constexpr bool l_q_leaf = std::same_as<L, mpq_class>;
        constexpr bool r_q_leaf = std::same_as<R, mpq_class>;
        constexpr bool l_scalar = scalar_operand<L>;
        constexpr bool r_scalar = scalar_operand<R>;

        if constexpr ((l_leaf || l_z_leaf || l_q_leaf || l_scalar) &&
                      (r_leaf || r_z_leaf || r_q_leaf || r_scalar)) {
            Op::apply(dst, lhs, rhs);
        } else if constexpr (!l_leaf && !l_z_leaf && !l_q_leaf && !l_scalar &&
                             (r_leaf || r_z_leaf || r_q_leaf || r_scalar)) {
            lhs.eval_to_prec(dst, final_prec);
            Op::apply(dst, dst, rhs);
        } else if constexpr ((l_leaf || l_z_leaf || l_q_leaf || l_scalar) &&
                             !r_leaf && !r_z_leaf && !r_q_leaf && !r_scalar) {
            rhs.eval_to_prec(dst, final_prec);
            Op::apply(dst, lhs, dst);
        } else {
            mpf_class tmp(gmpxx_mkII_detail::checked_mp_bitcnt(final_prec));
            rhs.eval_to_prec(tmp, final_prec);
            lhs.eval_to_prec(dst, final_prec);
            Op::apply(dst, dst, tmp);
        }
    }

    void eval_to_mpz(mpz_class& dst) const
        requires (std::same_as<result_type, mpz_class>) {
        constexpr bool l_value = std::same_as<L, mpz_class> || scalar_operand<L>;
        constexpr bool r_value = std::same_as<R, mpz_class> || scalar_operand<R>;
        if constexpr (l_value && r_value) {
            Op::apply(dst, lhs, rhs);
        } else if constexpr (!l_value && r_value) {
            lhs.eval_to_mpz(dst);
            Op::apply(dst, dst, rhs);
        } else if constexpr (l_value && !r_value) {
            rhs.eval_to_mpz(dst);
            Op::apply(dst, lhs, dst);
        } else {
            mpz_class tmp;
            rhs.eval_to_mpz(tmp);
            lhs.eval_to_mpz(dst);
            Op::apply(dst, dst, tmp);
        }
    }

    void eval_to_mpq(mpq_class& dst) const
        requires (std::same_as<result_type, mpq_class>) {
        constexpr bool l_value =
            std::same_as<L, mpq_class> || std::same_as<L, mpz_class> ||
            scalar_operand<L>;
        constexpr bool r_value =
            std::same_as<R, mpq_class> || std::same_as<R, mpz_class> ||
            scalar_operand<R>;
        if constexpr (l_value && r_value) {
            Op::apply(dst, lhs, rhs);
        } else if constexpr (!l_value && r_value) {
            lhs.eval_to_mpq(dst);
            Op::apply(dst, dst, rhs);
        } else if constexpr (l_value && !r_value) {
            rhs.eval_to_mpq(dst);
            Op::apply(dst, lhs, dst);
        } else {
            mpq_class tmp;
            rhs.eval_to_mpq(tmp);
            lhs.eval_to_mpq(dst);
            Op::apply(dst, dst, tmp);
        }
    }
};

template<class Derived>
[[nodiscard]] auto expr_base<Derived>::eval() const {
    using result_type = typename Derived::result_type;
    return result_type(self());
}

template<class Derived>
void expr_base<Derived>::eval_to(mpz_class& dst) const {
    self().eval_to_mpz(dst);
}

template<class Derived>
void expr_base<Derived>::eval_to(mpq_class& dst) const {
    self().eval_to_mpq(dst);
}

template<phase0_operand L, phase0_operand R>
[[nodiscard]] inline auto operator+(L const& l, R const& r) {
    return binary_expr<add_op, std::remove_cvref_t<L>, std::remove_cvref_t<R>>{l, r};
}

template<phase1_operand L, scalar_operand R>
    requires (!scalar_operand<L>)
[[nodiscard]] inline auto operator+(L const& l, R const& r) {
    using NR = scalar_normalize_t<R>;
    return binary_expr<add_op, std::remove_cvref_t<L>, NR>{
        l, static_cast<NR>(r)};
}

template<scalar_operand L, phase1_operand R>
    requires (!scalar_operand<R>)
[[nodiscard]] inline auto operator+(L const& l, R const& r) {
    using NL = scalar_normalize_t<L>;
    return binary_expr<add_op, NL, std::remove_cvref_t<R>>{
        static_cast<NL>(l), r};
}

template<phase2_operand L, phase2_operand R>
    requires (!(phase1_operand<L> && phase1_operand<R>) &&
              !(scalar_operand<L> && scalar_operand<R>))
[[nodiscard]] inline auto operator+(L const& l, R const& r) {
    using NL = gmpxx_mkII_detail::operand_storage_t<L>;
    using NR = gmpxx_mkII_detail::operand_storage_t<R>;
    if constexpr (scalar_operand<L> && !scalar_operand<R>) {
        return binary_expr<add_op, NL, std::remove_cvref_t<R>>{
            static_cast<NL>(l), r};
    } else if constexpr (!scalar_operand<L> && scalar_operand<R>) {
        return binary_expr<add_op, std::remove_cvref_t<L>, NR>{
            l, static_cast<NR>(r)};
    } else {
        return binary_expr<add_op, std::remove_cvref_t<L>, std::remove_cvref_t<R>>{
            l, r};
    }
}

template<phase0_operand L, phase0_operand R>
[[nodiscard]] inline auto operator-(L const& l, R const& r) {
    return binary_expr<sub_op, std::remove_cvref_t<L>, std::remove_cvref_t<R>>{l, r};
}

template<phase1_operand L, scalar_operand R>
    requires (!scalar_operand<L>)
[[nodiscard]] inline auto operator-(L const& l, R const& r) {
    using NR = scalar_normalize_t<R>;
    return binary_expr<sub_op, std::remove_cvref_t<L>, NR>{
        l, static_cast<NR>(r)};
}

