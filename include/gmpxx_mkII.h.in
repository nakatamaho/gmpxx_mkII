    mpf_mul(dst.get_mpf_t(), lhs.get_mpf_t(), tmp.get_mpf_t());
}

inline void mul_op::apply(mpf_class& dst, double lhs, mpf_class const& rhs) {
    apply(dst, rhs, lhs);
}

