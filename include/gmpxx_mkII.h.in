template<class Dst, class L, class R>
inline void div_op::apply(Dst& dst, L const& lhs, R const& rhs) {
    if constexpr (std::same_as<Dst, mpf_class>) {
        if constexpr (std::same_as<std::remove_cvref_t<L>, mpf_class>) {
            mpf_class tmp(dst.get_prec());
            gmpxx_mkII_detail::set_mpf_from_value(tmp, rhs);
            mpf_div(dst.get_mpf_t(), lhs.get_mpf_t(), tmp.get_mpf_t());
        } else if constexpr (std::same_as<std::remove_cvref_t<R>, mpf_class>) {
            mpf_class tmp(dst.get_prec());
            gmpxx_mkII_detail::set_mpf_from_value(tmp, lhs);
            mpf_div(dst.get_mpf_t(), tmp.get_mpf_t(), rhs.get_mpf_t());
        } else {
            mpf_class ltmp(dst.get_prec());
            mpf_class rtmp(dst.get_prec());
            gmpxx_mkII_detail::set_mpf_from_value(ltmp, lhs);
            gmpxx_mkII_detail::set_mpf_from_value(rtmp, rhs);
            mpf_div(dst.get_mpf_t(), ltmp.get_mpf_t(), rtmp.get_mpf_t());
        }
    } else if constexpr (std::same_as<Dst, mpz_class>) {
        if constexpr (std::same_as<std::remove_cvref_t<L>, mpz_class> &&
                      std::same_as<std::remove_cvref_t<R>, mpz_class>) {
            mpz_tdiv_q(dst.get_mpz_t(), lhs.get_mpz_t(), rhs.get_mpz_t());
        } else {
            mpz_class ltmp = gmpxx_mkII_detail::as_mpz(lhs);
            mpz_class rtmp = gmpxx_mkII_detail::as_mpz(rhs);
            mpz_tdiv_q(dst.get_mpz_t(), ltmp.get_mpz_t(), rtmp.get_mpz_t());
        }
    } else {
        if constexpr (std::same_as<std::remove_cvref_t<L>, mpq_class> &&
                      std::same_as<std::remove_cvref_t<R>, mpq_class>) {
            mpq_div(dst.get_mpq_t(), lhs.get_mpq_t(), rhs.get_mpq_t());
        } else {
            mpq_class ltmp = gmpxx_mkII_detail::as_mpq(lhs);
            mpq_class rtmp = gmpxx_mkII_detail::as_mpq(rhs);
            mpq_div(dst.get_mpq_t(), ltmp.get_mpq_t(), rtmp.get_mpq_t());
        }
    }
}

inline void add_op::apply(mpf_class& dst, mpf_class const& lhs,
                          mpf_class const& rhs) {
    mpf_add(dst.get_mpf_t(), lhs.get_mpf_t(), rhs.get_mpf_t());
}

inline void add_op::apply(mpf_class& dst, mpf_class const& lhs,
                          std::uint64_t rhs) {
    gmpxx_mkII_detail::add_mpf_uint(dst, lhs, rhs);
}

inline void add_op::apply(mpf_class& dst, std::uint64_t lhs,
                          mpf_class const& rhs) {
    apply(dst, rhs, lhs);
}

inline void add_op::apply(mpf_class& dst, mpf_class const& lhs,
                          std::int64_t rhs) {
    if (rhs >= 0) {
        apply(dst, lhs, static_cast<std::uint64_t>(rhs));
    } else {
        sub_op::apply(dst, lhs, gmpxx_mkII_detail::safe_negate(rhs));
    }
}

inline void add_op::apply(mpf_class& dst, std::int64_t lhs,
                          mpf_class const& rhs) {
    apply(dst, rhs, lhs);
}

inline void add_op::apply(mpf_class& dst, mpf_class const& lhs, double rhs) {
    mpf_class tmp = gmpxx_mkII_detail::double_tmp(rhs, dst.get_prec());
    mpf_add(dst.get_mpf_t(), lhs.get_mpf_t(), tmp.get_mpf_t());
}

inline void add_op::apply(mpf_class& dst, double lhs, mpf_class const& rhs) {
    apply(dst, rhs, lhs);
}

inline void sub_op::apply(mpf_class& dst, mpf_class const& lhs,
                          mpf_class const& rhs) {
    mpf_sub(dst.get_mpf_t(), lhs.get_mpf_t(), rhs.get_mpf_t());
}

inline void sub_op::apply(mpf_class& dst, mpf_class const& lhs,
                          std::uint64_t rhs) {
    gmpxx_mkII_detail::sub_mpf_uint(dst, lhs, rhs);
}

inline void sub_op::apply(mpf_class& dst, std::uint64_t lhs,
                          mpf_class const& rhs) {
    gmpxx_mkII_detail::sub_uint_mpf(dst, lhs, rhs);
}

inline void sub_op::apply(mpf_class& dst, mpf_class const& lhs,
                          std::int64_t rhs) {
    if (rhs >= 0) {
        apply(dst, lhs, static_cast<std::uint64_t>(rhs));
    } else {
        add_op::apply(dst, lhs, gmpxx_mkII_detail::safe_negate(rhs));
    }
}

inline void sub_op::apply(mpf_class& dst, std::int64_t lhs,
                          mpf_class const& rhs) {
    if (lhs >= 0) {
        apply(dst, static_cast<std::uint64_t>(lhs), rhs);
    } else {
        add_op::apply(dst, rhs, gmpxx_mkII_detail::safe_negate(lhs));
        mpf_neg(dst.get_mpf_t(), dst.get_mpf_t());
    }
}

inline void sub_op::apply(mpf_class& dst, mpf_class const& lhs, double rhs) {
    mpf_class tmp = gmpxx_mkII_detail::double_tmp(rhs, dst.get_prec());
    mpf_sub(dst.get_mpf_t(), lhs.get_mpf_t(), tmp.get_mpf_t());
}

inline void sub_op::apply(mpf_class& dst, double lhs, mpf_class const& rhs) {
    mpf_class tmp = gmpxx_mkII_detail::double_tmp(lhs, dst.get_prec());
    mpf_sub(dst.get_mpf_t(), tmp.get_mpf_t(), rhs.get_mpf_t());
}

