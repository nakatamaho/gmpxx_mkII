inline mpz_class& mpz_class::operator/=(mpz_class const& rhs) {
    mpz_tdiv_q(value, value, rhs.value);
    return *this;
}

inline mpz_class& mpz_class::operator%=(mpz_class const& rhs) {
    mpz_tdiv_r(value, value, rhs.value);
    return *this;
}

