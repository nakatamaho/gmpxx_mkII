template<phase0_operand L, phase0_operand R>
[[nodiscard]] inline auto operator/(L const& l, R const& r) {
    return binary_expr<div_op, std::remove_cvref_t<L>, std::remove_cvref_t<R>>{l, r};
}

template<phase1_operand L, scalar_operand R>
    requires (!scalar_operand<L>)
[[nodiscard]] inline auto operator/(L const& l, R const& r) {
    using NR = scalar_normalize_t<R>;
    return binary_expr<div_op, std::remove_cvref_t<L>, NR>{
        l, static_cast<NR>(r)};
