}

inline void div_op::apply(mpf_class& dst, std::uint64_t lhs,
                          mpf_class const& rhs) {
    gmpxx_detail::div_uint_mpf(dst, lhs, rhs);
}

inline void div_op::apply(mpf_class& dst, mpf_class const& lhs,
                          std::int64_t rhs) {
    if (rhs >= 0) {
        apply(dst, lhs, static_cast<std::uint64_t>(rhs));
    } else {
        apply(dst, lhs, gmpxx_detail::safe_negate(rhs));
        mpf_neg(dst.get_mpf_t(), dst.get_mpf_t());
    }
}

inline void div_op::apply(mpf_class& dst, std::int64_t lhs,
                          mpf_class const& rhs) {
    if (lhs >= 0) {
        apply(dst, static_cast<std::uint64_t>(lhs), rhs);
    } else {
        apply(dst, gmpxx_detail::safe_negate(lhs), rhs);
        mpf_neg(dst.get_mpf_t(), dst.get_mpf_t());
