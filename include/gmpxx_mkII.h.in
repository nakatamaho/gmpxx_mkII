#define GMPXX_MKII_VERSION_MAJOR 2
#define GMPXX_MKII_VERSION_MINOR 0
#define GMPXX_MKII_VERSION_PATCH 0
#define GMPXX_MKII_GIT_COMMIT_HASH "@GIT_COMMIT_HASH@"

namespace gmpxx_detail {

inline constexpr std::uint64_t effective_mpf_prec(std::uint64_t requested) noexcept {
    constexpr std::uint64_t limb_bits = GMP_NUMB_BITS;
    if (requested == 0) {
        return 0;
    }
    return ((requested + limb_bits - 1) / limb_bits) * limb_bits;
}

inline constexpr std::uint64_t normalize_mpf_prec(std::uint64_t requested) noexcept {
    return effective_mpf_prec(requested);
}

inline mp_bitcnt_t checked_mp_bitcnt(std::uint64_t prec) {
    if (prec == 0) {
        throw std::invalid_argument("gmpxx_mkII: precision must be strictly positive");
    }
    if constexpr (sizeof(mp_bitcnt_t) < sizeof(std::uint64_t)) {
        constexpr auto max_val =
            static_cast<std::uint64_t>(std::numeric_limits<mp_bitcnt_t>::max());
        if (prec > max_val) {
            throw std::overflow_error("gmpxx_mkII: precision exceeds mp_bitcnt_t range");
        }
    }
    return static_cast<mp_bitcnt_t>(prec);
}

inline std::uint64_t parse_default_prec_env() {
    char const* env = std::getenv("GMPXX_MKII_DEFAULT_PREC");
    if (env == nullptr || *env == '\0' || *env == '-') {
        return 512;
    }

    try {
        std::string s(env);
        std::size_t pos = 0;
        unsigned long long v = std::stoull(s, &pos, 10);
        if (pos != s.size() || v == 0) {
            return 512;
        }
        return static_cast<std::uint64_t>(v);
    } catch (...) {
        return 512;
    }
}

inline std::atomic<std::uint64_t>& process_initial_prec() {
    static std::atomic<std::uint64_t> v{parse_default_prec_env()};
    return v;
}

inline std::uint64_t thread_default_prec() {
    thread_local std::uint64_t prec =
        process_initial_prec().load(std::memory_order_relaxed);
    return prec;
}

inline constexpr int use_default_base = std::numeric_limits<int>::min();

inline void validate_default_base(int base) {
    if (base < 2 || base > 62) {
        throw std::invalid_argument("gmpxx_mkII: default base must be in [2, 62]");
    }
}

inline int& thread_default_base_ref() {
    thread_local int base = 10;
    return base;
}

inline int thread_default_base() noexcept {
    return thread_default_base_ref();
}

inline int normalize_base_arg(int base) noexcept {
    return base == use_default_base ? thread_default_base() : base;
}

class gmp_string {
public:
    explicit gmp_string(char* ptr) noexcept : ptr_(ptr) {}

    ~gmp_string() {
        reset();
    }

    gmp_string(gmp_string const&) = delete;
    gmp_string& operator=(gmp_string const&) = delete;

    gmp_string(gmp_string&& other) noexcept : ptr_(other.ptr_) {
        other.ptr_ = nullptr;
    }

    gmp_string& operator=(gmp_string&& other) noexcept {
        if (this != &other) {
            reset();
            ptr_ = other.ptr_;
            other.ptr_ = nullptr;
        }
        return *this;
    }

    [[nodiscard]] char const* c_str() const noexcept {
        return ptr_;
    }

    [[nodiscard]] explicit operator bool() const noexcept {
        return ptr_ != nullptr;
    }

private:
    void reset() noexcept {
        if (ptr_ == nullptr) {
            return;
        }

        void (*free_func)(void*, std::size_t) = nullptr;
        mp_get_memory_functions(nullptr, nullptr, &free_func);
        free_func(ptr_, std::strlen(ptr_) + 1);
        ptr_ = nullptr;
    }

    char* ptr_ = nullptr;
};

template<class T>
struct scalar_normalize_impl {};

template<class T>
    requires (std::is_floating_point_v<T> &&
              !std::is_same_v<T, long double>)
struct scalar_normalize_impl<T> {
    using type = double;
};

template<class T>
    requires (std::is_integral_v<T> && std::is_signed_v<T> &&
              !std::is_same_v<T, bool> &&
              (sizeof(T) <= sizeof(std::int64_t)))
struct scalar_normalize_impl<T> {
    using type = std::int64_t;
};

template<class T>
    requires (std::is_integral_v<T> && !std::is_signed_v<T> &&
              (sizeof(T) <= sizeof(std::uint64_t)))
struct scalar_normalize_impl<T> {
    using type = std::uint64_t;
};

}  // namespace gmpxx_detail

class gmpxx_defaults {
public:
    static void set_initial_default_prec(std::uint64_t bits) {
        if (bits == 0) {
            return;
        }
        gmpxx_detail::process_initial_prec().store(bits, std::memory_order_relaxed);
    }

    static std::uint64_t get_initial_default_prec() {
        return gmpxx_detail::process_initial_prec().load(std::memory_order_relaxed);
    }

    static mp_bitcnt_t get_default_prec() {
        return gmpxx_detail::checked_mp_bitcnt(
            gmpxx_detail::effective_mpf_prec(
                gmpxx_detail::thread_default_prec()));
    }

    static void set_default_base(int base) {
        gmpxx_detail::validate_default_base(base);
        gmpxx_detail::thread_default_base_ref() = base;
    }

    static int get_default_base() noexcept {
        return gmpxx_detail::thread_default_base();
    }
};

template<class T>
using scalar_normalize_t =
    typename gmpxx_detail::scalar_normalize_impl<std::remove_cvref_t<T>>::type;

class mpf_class;
class mpz_class;
class mpq_class;
class gmp_randclass;
class random_mpf_expr;

struct add_op;
struct sub_op;
struct mul_op;
struct div_op;
struct neg_op;
struct pos_op;

template<class Op, class X>
struct unary_expr;

template<class Op, class L, class R>
struct binary_expr;

template<class T>
inline constexpr bool is_gmpxx_expr_v = false;

template<class Op, class X>
inline constexpr bool is_gmpxx_expr_v<unary_expr<Op, X>> = true;

template<class Op, class L, class R>
inline constexpr bool is_gmpxx_expr_v<binary_expr<Op, L, R>> = true;

template<>
inline constexpr bool is_gmpxx_expr_v<random_mpf_expr> = true;

template<class T>
concept gmpxx_expr = is_gmpxx_expr_v<std::remove_cvref_t<T>>;

template<class T>
concept phase0_operand =
    std::same_as<std::remove_cvref_t<T>, mpf_class> || gmpxx_expr<T>;

template<class T>
concept scalar_operand =
    requires {
        typename scalar_normalize_t<T>;
    } &&
    !std::same_as<std::remove_cvref_t<T>, mpf_class> &&
    !is_gmpxx_expr_v<std::remove_cvref_t<T>>;

template<class T>
concept phase1_operand =
    phase0_operand<T> || scalar_operand<T>;

template<class T>
concept mpz_operand = std::same_as<std::remove_cvref_t<T>, mpz_class>;

template<class T>
concept mpq_operand = std::same_as<std::remove_cvref_t<T>, mpq_class>;

template<class T>
concept phase2_operand =
    phase1_operand<T> || mpz_operand<T> || mpq_operand<T>;

template<class T>
concept comparison_operand = phase2_operand<T>;

template<class L, class R>
concept comparison_pair =
    comparison_operand<L> &&
    comparison_operand<R> &&
    !(scalar_operand<L> && scalar_operand<R>);

namespace gmpxx_detail {

#if defined(GMPXX_MKII_INSTRUMENT_WRAPPERS)
inline std::atomic<std::uint64_t> mpf_ctor_count{0};
inline std::atomic<std::uint64_t> mpz_ctor_count{0};
inline std::atomic<std::uint64_t> mpq_ctor_count{0};

inline void reset_wrapper_counters() noexcept {
    mpf_ctor_count.store(0, std::memory_order_relaxed);
    mpz_ctor_count.store(0, std::memory_order_relaxed);
    mpq_ctor_count.store(0, std::memory_order_relaxed);
}
#endif

#if defined(GMPXX_MKII_TEST_FUSION_COUNTERS)
inline std::atomic<std::uint64_t> test_mpz_addmul_fused_count{0};
inline std::atomic<std::uint64_t> test_mpz_submul_fused_count{0};
inline std::atomic<std::uint64_t> test_mpz_addmul_ui_fused_count{0};
inline std::atomic<std::uint64_t> test_mpz_submul_ui_fused_count{0};

inline void reset_mpz_addmul_fusion_counters() noexcept {
    test_mpz_addmul_fused_count.store(0, std::memory_order_relaxed);
    test_mpz_submul_fused_count.store(0, std::memory_order_relaxed);
    test_mpz_addmul_ui_fused_count.store(0, std::memory_order_relaxed);
    test_mpz_submul_ui_fused_count.store(0, std::memory_order_relaxed);
}
#endif

enum class value_kind {
    mpf,
    mpz,
    mpq,
    scalar_int,
    scalar_uint,
    scalar_double
};

// Phase 2 operand/result dispatch table:
// - Any operation with mpf, or exact GMP value mixed with double, yields mpf.
// - Otherwise any operation with mpq yields mpq.
// - Otherwise any operation with mpz yields mpz.
// - scalar/scalar is rejected by operator constraints before reaching ET.
// GMP API routes:
// - mpf/mpf uses mpf_*; mpf with mpz/mpq converts the exact operand through
//   mpf_set_z/mpf_set_q because GMP has no mpf_*_z or mpf_*_q APIs.
// - mpz/mpz uses mpz_* and division uses mpz_tdiv_q.
// - mpq/mpq uses mpq_*; mpz/scalar exact operands are promoted to mpq by tmp.
// - double mixed with mpz/mpq promotes to mpf and uses mpf_set_d plus exact tmp.

template<class T>
struct value_kind_of;

template<>
struct value_kind_of<mpf_class> {
    static constexpr value_kind value = value_kind::mpf;
};

template<>
struct value_kind_of<mpz_class> {
    static constexpr value_kind value = value_kind::mpz;
};

template<>
struct value_kind_of<mpq_class> {
    static constexpr value_kind value = value_kind::mpq;
};

template<>
struct value_kind_of<std::int64_t> {
    static constexpr value_kind value = value_kind::scalar_int;
};

template<>
struct value_kind_of<std::uint64_t> {
    static constexpr value_kind value = value_kind::scalar_uint;
};

template<>
struct value_kind_of<double> {
    static constexpr value_kind value = value_kind::scalar_double;
};

template<class T>
struct kind_of_helper {
    using clean = std::remove_cvref_t<T>;
    static constexpr value_kind value = [] {
        if constexpr (is_gmpxx_expr_v<clean>) {
            return kind_of_helper<typename clean::result_type>::value;
        } else if constexpr (scalar_operand<clean>) {
            return value_kind_of<scalar_normalize_t<clean>>::value;
        } else {
            return value_kind_of<clean>::value;
        }
    }();
};

template<class T>
inline constexpr value_kind kind_of_v = kind_of_helper<T>::value;

template<value_kind LK, value_kind RK>
struct result_kind_impl {
    static constexpr bool has_mpf =
        LK == value_kind::mpf || RK == value_kind::mpf;
    static constexpr bool has_double =
        LK == value_kind::scalar_double || RK == value_kind::scalar_double;
    static constexpr bool has_mp_object =
        LK == value_kind::mpz || LK == value_kind::mpq ||
        RK == value_kind::mpz || RK == value_kind::mpq;
    static constexpr bool has_mpq =
        LK == value_kind::mpq || RK == value_kind::mpq;
    static constexpr bool has_mpz =
        LK == value_kind::mpz || RK == value_kind::mpz;

    static constexpr value_kind value =
        (has_mpf || (has_double && has_mp_object)) ? value_kind::mpf :
        has_mpq ? value_kind::mpq :
        has_mpz ? value_kind::mpz :
        has_double ? value_kind::mpf :
        value_kind::mpz;
};

template<class L, class R>
inline constexpr value_kind result_kind_v =
    result_kind_impl<kind_of_v<L>, kind_of_v<R>>::value;

template<value_kind K>
struct kind_to_type;

template<>
struct kind_to_type<value_kind::mpf> {
    using type = mpf_class;
};

template<>
struct kind_to_type<value_kind::mpz> {
    using type = mpz_class;
};

template<>
struct kind_to_type<value_kind::mpq> {
    using type = mpq_class;
};

template<class L, class R>
using result_type_t = typename kind_to_type<result_kind_v<L, R>>::type;

template<class T>
inline constexpr bool has_mpf_precision_v =
    kind_of_v<T> == value_kind::mpf;

template<class T, bool IsExpr = is_gmpxx_expr_v<std::remove_cvref_t<T>>>
struct result_or_self {
    using type = std::remove_cvref_t<T>;
};

template<class T>
struct result_or_self<T, true> {
    using type = typename std::remove_cvref_t<T>::result_type;
};

template<class T>
using result_or_self_t = typename result_or_self<T>::type;

#if defined(GMPXX_MKII_TEST_LLP64_PATH)
inline constexpr bool ulong_fits_uint64 = false;
#else
inline constexpr bool ulong_fits_uint64 =
    sizeof(unsigned long) >= sizeof(std::uint64_t);
#endif

inline bool fits_in_ulong(std::uint64_t v) noexcept {
    if constexpr (ulong_fits_uint64) {
        return true;
    } else {
#if defined(GMPXX_MKII_TEST_LLP64_PATH)
        constexpr std::uint64_t simulated_max = 0xFFFFFFFFu;
        return v <= simulated_max;
#else
        return v <= static_cast<std::uint64_t>(
            std::numeric_limits<unsigned long>::max());
#endif
    }
}

inline std::uint64_t safe_negate(std::int64_t v) noexcept {
    if (v == std::numeric_limits<std::int64_t>::min()) {
        return static_cast<std::uint64_t>(
                   std::numeric_limits<std::int64_t>::max()) +
               std::uint64_t{1};
    }
    return static_cast<std::uint64_t>(-(v + 1)) + std::uint64_t{1};
}

inline mp_bitcnt_t tmp_prec_for_integer(mp_bitcnt_t dst_prec) noexcept {
    return std::max(dst_prec, static_cast<mp_bitcnt_t>(64));
}

inline mp_bitcnt_t tmp_prec_for_double(mp_bitcnt_t dst_prec) noexcept {
    return std::max(dst_prec, static_cast<mp_bitcnt_t>(DBL_MANT_DIG));
}

inline bool is_power_of_two(std::uint64_t v) noexcept {
    return v != 0 && (v & (v - 1)) == 0;
}

inline mp_bitcnt_t power_of_two_exponent(std::uint64_t v) noexcept {
    return static_cast<mp_bitcnt_t>(std::countr_zero(v));
}

template<class T>
struct operand_storage {
    using type = T;
};

template<class T>
    requires scalar_operand<T>
struct operand_storage<T> {
    using type = scalar_normalize_t<T>;
};

template<class T>
using operand_storage_t =
    typename operand_storage<std::remove_cvref_t<T>>::type;

template<class T, bool IsScalar = scalar_operand<T>>
struct is_integral_scalar_leaf_impl : std::false_type {};

template<class T>
struct is_integral_scalar_leaf_impl<T, true>
    : std::bool_constant<
          std::same_as<scalar_normalize_t<T>, std::int64_t> ||
          std::same_as<scalar_normalize_t<T>, std::uint64_t>> {};

template<class T>
inline constexpr bool is_integral_scalar_leaf_v =
    is_integral_scalar_leaf_impl<std::remove_cvref_t<T>>::value;

template<class T>
inline constexpr bool is_mpz_addmul_operand_v =
    std::same_as<std::remove_cvref_t<T>, mpz_class> ||
    is_integral_scalar_leaf_v<T>;

template<class T>
struct is_mpz_addmul_fusable_impl : std::false_type {};

template<class L, class R>
struct is_mpz_addmul_fusable_impl<binary_expr<mul_op, L, R>>
    : std::bool_constant<
          is_mpz_addmul_operand_v<L> &&
          is_mpz_addmul_operand_v<R> &&
          (std::same_as<std::remove_cvref_t<L>, mpz_class> ||
           std::same_as<std::remove_cvref_t<R>, mpz_class>)> {};

template<class Expr>
inline constexpr bool is_mpz_addmul_fusable_v =
    is_mpz_addmul_fusable_impl<std::remove_cvref_t<Expr>>::value;

template<class Expr>
void addmul_fused_apply(mpz_class& dst, Expr const& expr);

template<class Expr>
void submul_fused_apply(mpz_class& dst, Expr const& expr);

}  // namespace gmpxx_detail

template<class Derived>
struct expr_base {
    [[nodiscard]] std::uint64_t suggested_prec() const {
#if defined(GMPXX_MKII_NOPRECCHANGE)
        return gmpxx_detail::thread_default_prec();
#else
        return self().suggested_prec_impl();
#endif
    }

    [[nodiscard]] auto eval() const;
    void eval_to(mpz_class& dst) const;
    void eval_to(mpq_class& dst) const;

private:
    [[nodiscard]] Derived const& self() const {
        return static_cast<Derived const&>(*this);
    }
};

class mpf_class {
public:
    mpf_class() {
        note_constructed();
        mpf_init2(value, gmpxx_detail::checked_mp_bitcnt(
                             gmpxx_detail::thread_default_prec()));
    }

    explicit mpf_class(mp_bitcnt_t prec) {
        note_constructed();
        mpf_init2(value, prec);
    }

    mpf_class(double v) : mpf_class() {
        mpf_set_d(value, v);
    }

    mpf_class(double v, mp_bitcnt_t prec) : mpf_class(prec) {
        mpf_set_d(value, v);
    }

    mpf_class(bool, mp_bitcnt_t) = delete;

    template<class T>
        requires (std::is_integral_v<std::remove_cvref_t<T>> &&
                  !std::same_as<std::remove_cvref_t<T>, bool> &&
                  (sizeof(std::remove_cvref_t<T>) <= sizeof(std::uint64_t)))
    mpf_class(T v, mp_bitcnt_t prec) : mpf_class(prec) {
        set_from_integral(v);
    }

    mpf_class(mpz_class const& v, mp_bitcnt_t prec);

    explicit mpf_class(char const* s) : mpf_class() {
        set_from_string(s, gmpxx_detail::use_default_base);
    }

    mpf_class(char const* s, mp_bitcnt_t prec,
              int base = gmpxx_detail::use_default_base) : mpf_class(prec) {
        set_from_string(s, base);
    }

    explicit mpf_class(std::string const& s) : mpf_class(s.c_str()) {}

    mpf_class(std::string const& s, mp_bitcnt_t prec,
              int base = gmpxx_detail::use_default_base)
        : mpf_class(s.c_str(), prec, base) {}

    mpf_class(mpf_class const& other) {
        note_constructed();
        mpf_init2(value, other.get_prec());
        mpf_set(value, other.value);
    }

    mpf_class(mpf_class&& other) noexcept {
        note_constructed();
        mpf_init2(value, other.get_prec());
        mpf_swap(value, other.value);
    }

    template<gmpxx_expr Expr>
        requires (std::same_as<typename Expr::result_type, mpf_class>)
    mpf_class(Expr const& expr) {
        note_constructed();
        std::uint64_t final_prec = expr.suggested_prec();
        mpf_init2(value, gmpxx_detail::checked_mp_bitcnt(final_prec));
        expr.eval_to_prec(*this, final_prec);
    }

    ~mpf_class() {
        mpf_clear(value);
    }

    mpf_class& operator=(mpf_class const& other) {
        if (this != &other) {
            if (get_prec() != other.get_prec()) {
                mpf_set_prec(value, other.get_prec());
            }
            mpf_set(value, other.value);
        }
        return *this;
    }

    mpf_class& operator=(mpf_class&& other) noexcept {
        if (this != &other) {
            mpf_swap(value, other.value);
        }
        return *this;
    }

    mpf_class& operator=(double rhs) {
        mpf_set_d(value, rhs);
        return *this;
    }

    mpf_class& operator=(char const* rhs) {
        if (set_str(rhs) != 0) {
            throw std::invalid_argument("gmpxx_mkII: invalid mpf string");
        }
        return *this;
    }

    mpf_class& operator=(std::string const& rhs) {
        return *this = rhs.c_str();
    }

    template<gmpxx_expr Expr>
        requires (std::same_as<typename Expr::result_type, mpf_class>)
    mpf_class& operator=(Expr const& expr) {
        std::uint64_t final_prec = static_cast<std::uint64_t>(get_prec());
        if (expr.contains_address(this)) {
            mpf_class tmp(gmpxx_detail::checked_mp_bitcnt(final_prec));
            expr.eval_to_prec(tmp, final_prec);
            mpf_set(value, tmp.value);
            return *this;
        }

        expr.eval_to_prec(*this, final_prec);
        return *this;
    }

    mpf_class& operator+=(mpf_class const& rhs);
    mpf_class& operator-=(mpf_class const& rhs);
    mpf_class& operator*=(mpf_class const& rhs);
    mpf_class& operator/=(mpf_class const& rhs);

    template<gmpxx_expr Expr>
        requires (std::same_as<typename Expr::result_type, mpf_class>)
    mpf_class& operator+=(Expr const& expr);

    template<gmpxx_expr Expr>
        requires (std::same_as<typename Expr::result_type, mpf_class>)
    mpf_class& operator-=(Expr const& expr);

    template<gmpxx_expr Expr>
        requires (std::same_as<typename Expr::result_type, mpf_class>)
    mpf_class& operator*=(Expr const& expr);

    template<gmpxx_expr Expr>
        requires (std::same_as<typename Expr::result_type, mpf_class>)
    mpf_class& operator/=(Expr const& expr);

    template<scalar_operand T>
    mpf_class& operator+=(T const& rhs);

    template<scalar_operand T>
    mpf_class& operator-=(T const& rhs);

    template<scalar_operand T>
    mpf_class& operator*=(T const& rhs);

    template<scalar_operand T>
    mpf_class& operator/=(T const& rhs);

    [[nodiscard]] mpf_ptr get_mpf_t() {
        return value;
    }

    [[nodiscard]] mpf_srcptr get_mpf_t() const {
        return value;
    }

    [[nodiscard]] mp_bitcnt_t get_prec() const {
        return mpf_get_prec(value);
    }

    [[nodiscard]] double get_d() const {
        return mpf_get_d(value);
    }

    [[nodiscard]] unsigned long get_ui() const {
        return mpf_get_ui(value);
    }

    [[nodiscard]] signed long get_si() const {
        return mpf_get_si(value);
    }

    [[nodiscard]] bool fits_sint_p() const {
        return mpf_fits_sint_p(value) != 0;
    }

    [[nodiscard]] bool fits_slong_p() const {
        return mpf_fits_slong_p(value) != 0;
    }

    [[nodiscard]] bool fits_sshort_p() const {
        return mpf_fits_sshort_p(value) != 0;
    }

    [[nodiscard]] bool fits_uint_p() const {
        return mpf_fits_uint_p(value) != 0;
    }

    [[nodiscard]] bool fits_ulong_p() const {
        return mpf_fits_ulong_p(value) != 0;
    }

    [[nodiscard]] bool fits_ushort_p() const {
        return mpf_fits_ushort_p(value) != 0;
    }

    void mul_2exp(mp_bitcnt_t exp) {
        mpf_mul_2exp(value, value, exp);
    }

    void div_2exp(mp_bitcnt_t exp) {
        mpf_div_2exp(value, value, exp);
    }

    [[nodiscard]] std::string get_str(
        mp_exp_t& exp,
        int base = gmpxx_detail::use_default_base,
        std::size_t n_digits = 0) const {
        gmpxx_detail::gmp_string s(
            mpf_get_str(nullptr, &exp, gmpxx_detail::normalize_base_arg(base),
                        n_digits, value));
        return s ? std::string(s.c_str()) : std::string();
    }

    int set_str(char const* s, int base = gmpxx_detail::use_default_base) {
        mpf_class tmp(get_prec());
        int rc = mpf_set_str(
            tmp.value, s, gmpxx_detail::normalize_base_arg(base));
        if (rc == 0) {
            mpf_set(value, tmp.value);
        }
        return rc;
    }

    int set_str(std::string const& s,
                int base = gmpxx_detail::use_default_base) {
        return set_str(s.c_str(), base);
    }

    [[nodiscard]] std::string to_string(std::size_t n_digits = 0) const;

    [[nodiscard]] bool contains_address(mpf_class const* p) const {
        return this == p;
    }

    void swap(mpf_class& other) noexcept {
        mpf_swap(value, other.value);
    }

private:
    static void note_constructed() noexcept {
#if defined(GMPXX_MKII_INSTRUMENT_WRAPPERS)
        gmpxx_detail::mpf_ctor_count.fetch_add(1, std::memory_order_relaxed);
#endif
    }

    void set_from_string(char const* s, int base) {
        if (mpf_set_str(value, s, gmpxx_detail::normalize_base_arg(base)) != 0) {
            throw std::invalid_argument("gmpxx_mkII: invalid mpf string");
        }
    }

    template<class T>
        requires (std::is_integral_v<std::remove_cvref_t<T>> &&
                  !std::same_as<std::remove_cvref_t<T>, bool> &&
                  (sizeof(std::remove_cvref_t<T>) <= sizeof(std::uint64_t)))
    void set_from_integral(T v);

    mpf_t value;
};

class mpz_class {
public:
    using result_type = mpz_class;

    mpz_class() {
        note_constructed();
        mpz_init(value);
    }

    mpz_class(mpz_class const& other) {
        note_constructed();
        mpz_init_set(value, other.value);
    }

    mpz_class(mpz_class&& other) noexcept {
        note_constructed();
        mpz_init(value);
        mpz_swap(value, other.value);
    }

    mpz_class(std::int64_t v) : mpz_class() {
        set_i64(v);
    }

    mpz_class(std::uint64_t v) : mpz_class() {
        set_u64(v);
    }

    mpz_class(double v) : mpz_class() {
        mpz_set_d(value, v);
    }

    mpz_class(char const* s, int base = gmpxx_detail::use_default_base)
        : mpz_class() {
        if (mpz_set_str(value, s, gmpxx_detail::normalize_base_arg(base)) != 0) {
            throw std::invalid_argument("gmpxx_mkII: invalid mpz string");
        }
    }

    mpz_class(std::string const& s,
              int base = gmpxx_detail::use_default_base)
        : mpz_class(s.c_str(), base) {}

    template<gmpxx_expr Expr>
        requires (std::same_as<typename Expr::result_type, mpz_class>)
    mpz_class(Expr const& expr) : mpz_class() {
        expr.eval_to(*this);
    }

    ~mpz_class() {
        mpz_clear(value);
    }

    mpz_class& operator=(mpz_class const& other) {
        if (this != &other) {
            mpz_set(value, other.value);
        }
        return *this;
    }

    mpz_class& operator=(mpz_class&& other) noexcept {
        if (this != &other) {
            mpz_swap(value, other.value);
        }
        return *this;
    }

    template<gmpxx_expr Expr>
        requires (std::same_as<typename Expr::result_type, mpz_class>)
    mpz_class& operator=(Expr const& expr) {
        if (expr.contains_address(this)) {
            mpz_class tmp;
            expr.eval_to(tmp);
            swap(tmp);
        } else {
            expr.eval_to(*this);
        }
        return *this;
    }

    mpz_class& operator+=(mpz_class const& rhs);
    mpz_class& operator-=(mpz_class const& rhs);
    mpz_class& operator*=(mpz_class const& rhs);
    mpz_class& operator/=(mpz_class const& rhs);
    mpz_class& operator%=(mpz_class const& rhs);

    template<gmpxx_expr Expr>
        requires (std::same_as<typename Expr::result_type, mpz_class>)
    mpz_class& operator+=(Expr const& expr);
    template<gmpxx_expr Expr>
        requires (std::same_as<typename Expr::result_type, mpz_class>)
    mpz_class& operator-=(Expr const& expr);
    template<gmpxx_expr Expr>
        requires (std::same_as<typename Expr::result_type, mpz_class>)
    mpz_class& operator*=(Expr const& expr);
    template<gmpxx_expr Expr>
        requires (std::same_as<typename Expr::result_type, mpz_class>)
    mpz_class& operator/=(Expr const& expr);

    template<scalar_operand T>
    mpz_class& operator+=(T const& rhs);
    template<scalar_operand T>
    mpz_class& operator-=(T const& rhs);
    template<scalar_operand T>
    mpz_class& operator*=(T const& rhs);
    template<scalar_operand T>
    mpz_class& operator/=(T const& rhs);

    [[nodiscard]] mpz_ptr get_mpz_t() {
        return value;
    }

    [[nodiscard]] mpz_srcptr get_mpz_t() const {
        return value;
    }

    [[nodiscard]] std::string get_str(
        int base = gmpxx_detail::use_default_base) const {
        gmpxx_detail::gmp_string s(mpz_get_str(
            nullptr, gmpxx_detail::normalize_base_arg(base), value));
        return s ? std::string(s.c_str()) : std::string();
    }

    int set_str(char const* s, int base = gmpxx_detail::use_default_base) {
        mpz_class tmp;
        int rc = mpz_set_str(
            tmp.value, s, gmpxx_detail::normalize_base_arg(base));
        if (rc == 0) {
            swap(tmp);
        }
        return rc;
    }

    int set_str(std::string const& s,
                int base = gmpxx_detail::use_default_base) {
        return set_str(s.c_str(), base);
    }

    [[nodiscard]] std::string to_string(
        int base = gmpxx_detail::use_default_base) const {
        return get_str(base);
    }

    [[nodiscard]] double get_d() const {
        return mpz_get_d(value);
    }

    [[nodiscard]] signed long get_si() const {
        return mpz_get_si(value);
    }

    [[nodiscard]] unsigned long get_ui() const {
        return mpz_get_ui(value);
    }

    [[nodiscard]] bool fits_sint_p() const {
        return mpz_fits_sint_p(value) != 0;
    }

    [[nodiscard]] bool fits_slong_p() const {
        return mpz_fits_slong_p(value) != 0;
    }

    [[nodiscard]] bool fits_sshort_p() const {
        return mpz_fits_sshort_p(value) != 0;
    }

    [[nodiscard]] bool fits_uint_p() const {
        return mpz_fits_uint_p(value) != 0;
    }

    [[nodiscard]] bool fits_ulong_p() const {
        return mpz_fits_ulong_p(value) != 0;
    }

    [[nodiscard]] bool fits_ushort_p() const {
        return mpz_fits_ushort_p(value) != 0;
    }

    [[nodiscard]] bool contains_address(mpz_class const* p) const {
        return this == p;
    }

    void swap(mpz_class& other) noexcept {
        mpz_swap(value, other.value);
    }

    [[nodiscard]] int sgn() const {
        return mpz_sgn(value);
    }

private:
    static void note_constructed() noexcept {
#if defined(GMPXX_MKII_INSTRUMENT_WRAPPERS)
        gmpxx_detail::mpz_ctor_count.fetch_add(1, std::memory_order_relaxed);
#endif
    }

    void set_u64(std::uint64_t v) {
        mpz_import(value, 1, -1, sizeof(v), 0, 0, &v);
    }

    void set_i64(std::int64_t v) {
        if (v < 0) {
            set_u64(gmpxx_detail::safe_negate(v));
            mpz_neg(value, value);
        } else {
            set_u64(static_cast<std::uint64_t>(v));
        }
    }

    mpz_t value;
};

template<class T>
    requires (std::is_integral_v<std::remove_cvref_t<T>> &&
              !std::same_as<std::remove_cvref_t<T>, bool> &&
              (sizeof(std::remove_cvref_t<T>) <= sizeof(std::uint64_t)))
void mpf_class::set_from_integral(T v) {
    using clean = std::remove_cvref_t<T>;
    if constexpr (std::is_signed_v<clean>) {
        mpz_class z(static_cast<std::int64_t>(v));
        mpf_set_z(value, z.get_mpz_t());
    } else {
        mpz_class z(static_cast<std::uint64_t>(v));
        mpf_set_z(value, z.get_mpz_t());
    }
}

inline mpf_class::mpf_class(mpz_class const& v, mp_bitcnt_t prec)
    : mpf_class(prec) {
    mpf_set_z(value, v.get_mpz_t());
}

class mpq_class {
public:
    using result_type = mpq_class;

    mpq_class() {
        note_constructed();
        mpq_init(value);
    }

    mpq_class(mpq_class const& other) {
        note_constructed();
        mpq_init(value);
        mpq_set(value, other.value);
    }

    mpq_class(mpq_class&& other) noexcept {
        note_constructed();
        mpq_init(value);
        mpq_swap(value, other.value);
    }

    mpq_class(std::int64_t num, std::int64_t den = 1) : mpq_class() {
        mpz_class n(num);
        mpz_class d(den);
        mpq_set_num(value, n.get_mpz_t());
        mpq_set_den(value, d.get_mpz_t());
        canonicalize();
    }

    mpq_class(mpz_class const& num) : mpq_class() {
        mpq_set_z(value, num.get_mpz_t());
    }

    mpq_class(mpz_class const& num, mpz_class const& den) : mpq_class() {
        mpq_set_num(value, num.get_mpz_t());
        mpq_set_den(value, den.get_mpz_t());
        canonicalize();
    }

    mpq_class(double v) : mpq_class() {
        mpq_set_d(value, v);
        canonicalize();
    }

    mpq_class(char const* s, int base = gmpxx_detail::use_default_base)
        : mpq_class() {
        if (mpq_set_str(value, s, gmpxx_detail::normalize_base_arg(base)) != 0) {
            throw std::invalid_argument("gmpxx_mkII: invalid mpq string");
        }
        canonicalize();
    }

    mpq_class(std::string const& s,
              int base = gmpxx_detail::use_default_base)
        : mpq_class(s.c_str(), base) {}

    template<gmpxx_expr Expr>
        requires (std::same_as<typename Expr::result_type, mpq_class>)
    mpq_class(Expr const& expr) : mpq_class() {
        expr.eval_to(*this);
    }

    ~mpq_class() {
        mpq_clear(value);
    }

    mpq_class& operator=(mpq_class const& other) {
        if (this != &other) {
            mpq_set(value, other.value);
        }
        return *this;
    }

    mpq_class& operator=(mpq_class&& other) noexcept {
        if (this != &other) {
            mpq_swap(value, other.value);
        }
        return *this;
    }

    template<gmpxx_expr Expr>
        requires (std::same_as<typename Expr::result_type, mpq_class>)
    mpq_class& operator=(Expr const& expr) {
        if (expr.contains_address(this)) {
            mpq_class tmp;
            expr.eval_to(tmp);
            swap(tmp);
        } else {
            expr.eval_to(*this);
        }
        return *this;
    }

    mpq_class& operator+=(mpq_class const& rhs);
    mpq_class& operator-=(mpq_class const& rhs);
    mpq_class& operator*=(mpq_class const& rhs);
    mpq_class& operator/=(mpq_class const& rhs);

    template<gmpxx_expr Expr>
        requires (std::same_as<typename Expr::result_type, mpq_class>)
    mpq_class& operator+=(Expr const& expr);
    template<gmpxx_expr Expr>
        requires (std::same_as<typename Expr::result_type, mpq_class>)
    mpq_class& operator-=(Expr const& expr);
    template<gmpxx_expr Expr>
        requires (std::same_as<typename Expr::result_type, mpq_class>)
    mpq_class& operator*=(Expr const& expr);
    template<gmpxx_expr Expr>
        requires (std::same_as<typename Expr::result_type, mpq_class>)
    mpq_class& operator/=(Expr const& expr);

    template<scalar_operand T>
    mpq_class& operator+=(T const& rhs);
    template<scalar_operand T>
    mpq_class& operator-=(T const& rhs);
    template<scalar_operand T>
    mpq_class& operator*=(T const& rhs);
    template<scalar_operand T>
    mpq_class& operator/=(T const& rhs);

    [[nodiscard]] mpq_ptr get_mpq_t() {
        return value;
    }

    [[nodiscard]] mpq_srcptr get_mpq_t() const {
        return value;
    }

    [[nodiscard]] std::string get_str(
        int base = gmpxx_detail::use_default_base) const {
        gmpxx_detail::gmp_string s(mpq_get_str(
            nullptr, gmpxx_detail::normalize_base_arg(base), value));
        return s ? std::string(s.c_str()) : std::string();
    }

    int set_str(char const* s, int base = gmpxx_detail::use_default_base) {
        mpq_class tmp;
        int rc = mpq_set_str(
            tmp.value, s, gmpxx_detail::normalize_base_arg(base));
        if (rc == 0) {
            tmp.canonicalize();
            swap(tmp);
        }
        return rc;
    }

    int set_str(std::string const& s,
                int base = gmpxx_detail::use_default_base) {
        return set_str(s.c_str(), base);
    }

    [[nodiscard]] std::string to_string(
        int base = gmpxx_detail::use_default_base) const {
        return get_str(base);
    }

    [[nodiscard]] double get_d() const {
        return mpq_get_d(value);
    }

    [[nodiscard]] mpz_class get_num() const {
        mpz_class r;
        mpz_set(r.get_mpz_t(), mpq_numref(value));
        return r;
    }

    [[nodiscard]] mpz_class get_den() const {
        mpz_class r;
        mpz_set(r.get_mpz_t(), mpq_denref(value));
        return r;
    }

    [[nodiscard]] mpz_srcptr get_num_mpz_t() const {
        return mpq_numref(value);
    }

    [[nodiscard]] mpz_srcptr get_den_mpz_t() const {
        return mpq_denref(value);
    }

    [[nodiscard]] bool contains_address(mpq_class const* p) const {
        return this == p;
    }

    void swap(mpq_class& other) noexcept {
        mpq_swap(value, other.value);
    }

    [[nodiscard]] int sgn() const {
        return mpq_sgn(value);
    }

    void canonicalize() {
        mpq_canonicalize(value);
    }

private:
    static void note_constructed() noexcept {
#if defined(GMPXX_MKII_INSTRUMENT_WRAPPERS)
        gmpxx_detail::mpq_ctor_count.fetch_add(1, std::memory_order_relaxed);
#endif
    }

    mpq_t value;
};

class gmp_randclass {
public:
    gmp_randclass() {
        gmp_randinit_default(state);
        initialized_ = true;
    }

    explicit gmp_randclass(void (*init_function)(gmp_randstate_t)) {
        init_function(state);
        initialized_ = true;
    }

    gmp_randclass(
        void (*init_function)(gmp_randstate_t, mpz_srcptr, unsigned long,
                              mp_bitcnt_t),
        mpz_class const& a,
        unsigned long c,
        mp_bitcnt_t m2exp) {
        init_function(state, a.get_mpz_t(), c, m2exp);
        initialized_ = true;
    }

    gmp_randclass(int (*init_function)(gmp_randstate_t, mp_bitcnt_t),
                  mp_bitcnt_t size) {
        if (size > 128) {
            throw std::length_error("gmpxx_mkII: random size is too large");
        }
        if (init_function(state, size) == 0) {
            throw std::length_error("gmpxx_mkII: random initialization failed");
        }
        initialized_ = true;
    }

    gmp_randclass(gmp_randalg_t alg, mp_bitcnt_t size) {
        initialize_obsolete(alg, size);
    }

    gmp_randclass(gmp_randclass const&) = delete;
    gmp_randclass& operator=(gmp_randclass const&) = delete;
    gmp_randclass(gmp_randclass&&) = delete;
    gmp_randclass& operator=(gmp_randclass&&) = delete;

    ~gmp_randclass() {
        if (initialized_) {
            gmp_randclear(state);
        }
    }

    void seed(unsigned long int s) {
        gmp_randseed_ui(state, s);
    }

    void seed(mpz_class const& s) {
        gmp_randseed(state, s.get_mpz_t());
    }

    [[nodiscard]] mpz_class get_z_bits(mp_bitcnt_t bits) {
        mpz_class result;
        mpz_urandomb(result.get_mpz_t(), state, bits);
        return result;
    }

    [[nodiscard]] mpz_class get_z_bits(mpz_class const& bits) {
        if (mpz_sgn(bits.get_mpz_t()) < 0) {
            throw std::invalid_argument("gmpxx_mkII: random bit count is negative");
        }
        if (!mpz_fits_ulong_p(bits.get_mpz_t())) {
            throw std::overflow_error("gmpxx_mkII: random bit count is too large");
        }
        return get_z_bits(gmpxx_detail::checked_mp_bitcnt(
            static_cast<std::uint64_t>(mpz_get_ui(bits.get_mpz_t()))));
    }

    [[nodiscard]] mpz_class get_z_range(mpz_class const& n) {
        mpz_class result;
        mpz_urandomm(result.get_mpz_t(), state, n.get_mpz_t());
        return result;
    }

    [[nodiscard]] random_mpf_expr get_f();

    [[nodiscard]] mpf_class get_f(mpf_class const& op) {
        return get_f(op.get_prec());
    }

    [[nodiscard]] mpf_class get_f(mp_bitcnt_t prec) {
        mp_bitcnt_t result_prec =
            prec == 0 ? gmpxx_defaults::get_default_prec() : prec;
        mpf_class result(result_prec);
        generate_mpf(result, result_prec);
        return result;
    }

private:
    friend class random_mpf_expr;

    void generate_mpf(mpf_class& dst, mp_bitcnt_t prec) {
        mpf_urandomb(dst.get_mpf_t(), state, prec);
    }

    void initialize_obsolete(gmp_randalg_t alg, mp_bitcnt_t size) {
        switch (alg) {
        case GMP_RAND_ALG_LC:
            if (size > 128) {
                gmp_errno |= GMP_ERROR_INVALID_ARGUMENT;
                throw std::length_error("gmpxx_mkII: random size is too large");
            }
            if (gmp_randinit_lc_2exp_size(state, size) == 0) {
                gmp_errno |= GMP_ERROR_INVALID_ARGUMENT;
                throw std::length_error("gmpxx_mkII: random initialization failed");
            }
            initialized_ = true;
            break;
        default:
            gmp_errno |= GMP_ERROR_UNSUPPORTED_ARGUMENT;
            throw std::invalid_argument("gmpxx_mkII: unsupported random algorithm");
        }
    }

    gmp_randstate_t state;
    bool initialized_{false};
};

class random_mpf_expr {
public:
    using result_type = mpf_class;

    explicit random_mpf_expr(gmp_randclass& rng) noexcept : rng_(&rng) {}

    [[nodiscard]] std::uint64_t suggested_prec() const {
        return static_cast<std::uint64_t>(gmpxx_defaults::get_default_prec());
    }

    [[nodiscard]] mpf_class eval() const {
        std::uint64_t final_prec = suggested_prec();
        mpf_class result(gmpxx_detail::checked_mp_bitcnt(final_prec));
        eval_to_prec(result, final_prec);
        return result;
    }

    void eval_to_prec(mpf_class& dst, std::uint64_t final_prec) const {
        mp_bitcnt_t prec = gmpxx_detail::checked_mp_bitcnt(final_prec);
        rng_->generate_mpf(dst, prec);
    }

    [[nodiscard]] bool contains_address(mpf_class const*) const noexcept {
        return false;
    }

    [[nodiscard]] bool contains_address(mpz_class const*) const noexcept {
        return false;
    }

    [[nodiscard]] bool contains_address(mpq_class const*) const noexcept {
        return false;
    }

private:
    gmp_randclass* rng_;
};

inline random_mpf_expr gmp_randclass::get_f() {
    return random_mpf_expr(*this);
}

inline std::string mpf_class::to_string(std::size_t n_digits) const {
    mp_exp_t exp = 0;
    std::string digits = get_str(exp, 10, n_digits);
    if (digits.empty()) {
        return "0";
    }

    bool negative = digits.front() == '-';
    if (negative) {
        digits.erase(digits.begin());
    }

    std::string out;
    if (negative) {
        out.push_back('-');
    }

    if (exp <= 0) {
        out += "0.";
        out.append(static_cast<std::size_t>(-exp), '0');
        out += digits;
    } else if (static_cast<std::size_t>(exp) >= digits.size()) {
        out += digits;
        out.append(static_cast<std::size_t>(exp) - digits.size(), '0');
    } else {
        out += digits.substr(0, static_cast<std::size_t>(exp));
        out.push_back('.');
        out += digits.substr(static_cast<std::size_t>(exp));
    }

    return out;
}

namespace gmpxx_detail {

inline int stream_integer_base(std::ios_base const& os) noexcept {
    auto basefield = os.flags() & std::ios_base::basefield;
    if (basefield == std::ios_base::hex) {
        return (os.flags() & std::ios_base::uppercase) ? -16 : 16;
    }
    if (basefield == std::ios_base::oct) {
        return 8;
    }
    return 10;
}

inline int stream_input_base(std::ios_base const& is) noexcept {
    auto basefield = is.flags() & std::ios_base::basefield;
    if (basefield == std::ios_base::hex) {
        return 16;
    }
    if (basefield == std::ios_base::oct) {
        return 8;
    }
    if (basefield == std::ios_base::dec) {
        return 10;
    }
    return 0;
}

inline std::string mpf_format_string(std::ios_base const& os) {
    char conv = 'g';
    auto floatfield = os.flags() & std::ios_base::floatfield;
    if (floatfield == std::ios_base::scientific) {
        conv = 'e';
    } else if (floatfield == std::ios_base::fixed) {
        conv = 'f';
    }

    if (os.flags() & std::ios_base::uppercase) {
        conv = static_cast<char>(conv - 'a' + 'A');
    }

    std::string fmt = "%.*F";
    fmt.push_back(conv);
    return fmt;
}

inline std::string format_mpf(mpf_class const& value, std::ios_base const& os) {
    std::streamsize stream_prec = os.precision();
    if (stream_prec < 0) {
        stream_prec = 6;
    }
    if (stream_prec > static_cast<std::streamsize>(std::numeric_limits<int>::max())) {
        stream_prec = std::numeric_limits<int>::max();
    }

    char* raw = nullptr;
    int count = gmp_asprintf(
        &raw, mpf_format_string(os).c_str(), static_cast<int>(stream_prec),
        value.get_mpf_t());
    gmp_string formatted(raw);
    if (count < 0 || !formatted) {
        return {};
    }
    return std::string(formatted.c_str());
}

inline mpf_class integer_tmp(std::uint64_t v, mp_bitcnt_t dst_prec) {
    char buf[24];
    std::snprintf(buf, sizeof(buf), "%llu",
                  static_cast<unsigned long long>(v));
    return mpf_class(buf, tmp_prec_for_integer(dst_prec), 10);
}

inline mpf_class double_tmp(double v, mp_bitcnt_t dst_prec) {
    return mpf_class(v, tmp_prec_for_double(dst_prec));
}

inline void add_mpf_uint(mpf_class& dst, mpf_class const& lhs, std::uint64_t rhs) {
    if constexpr (ulong_fits_uint64) {
        mpf_add_ui(dst.get_mpf_t(), lhs.get_mpf_t(),
                   static_cast<unsigned long>(rhs));
    } else {
        if (fits_in_ulong(rhs)) {
            mpf_add_ui(dst.get_mpf_t(), lhs.get_mpf_t(),
                       static_cast<unsigned long>(rhs));
        } else {
            mpf_class tmp = integer_tmp(rhs, dst.get_prec());
            mpf_add(dst.get_mpf_t(), lhs.get_mpf_t(), tmp.get_mpf_t());
        }
    }
}

inline void sub_mpf_uint(mpf_class& dst, mpf_class const& lhs, std::uint64_t rhs) {
    if constexpr (ulong_fits_uint64) {
        mpf_sub_ui(dst.get_mpf_t(), lhs.get_mpf_t(),
                   static_cast<unsigned long>(rhs));
    } else {
        if (fits_in_ulong(rhs)) {
            mpf_sub_ui(dst.get_mpf_t(), lhs.get_mpf_t(),
                       static_cast<unsigned long>(rhs));
        } else {
            mpf_class tmp = integer_tmp(rhs, dst.get_prec());
            mpf_sub(dst.get_mpf_t(), lhs.get_mpf_t(), tmp.get_mpf_t());
        }
    }
}

inline void sub_uint_mpf(mpf_class& dst, std::uint64_t lhs, mpf_class const& rhs) {
    if constexpr (ulong_fits_uint64) {
        mpf_ui_sub(dst.get_mpf_t(), static_cast<unsigned long>(lhs),
                   rhs.get_mpf_t());
    } else {
        if (fits_in_ulong(lhs)) {
            mpf_ui_sub(dst.get_mpf_t(), static_cast<unsigned long>(lhs),
                       rhs.get_mpf_t());
        } else {
            mpf_class tmp = integer_tmp(lhs, dst.get_prec());
            mpf_sub(dst.get_mpf_t(), tmp.get_mpf_t(), rhs.get_mpf_t());
        }
    }
}

inline void mul_mpf_uint(mpf_class& dst, mpf_class const& lhs, std::uint64_t rhs) {
    if (is_power_of_two(rhs)) {
        mpf_mul_2exp(dst.get_mpf_t(), lhs.get_mpf_t(),
                     power_of_two_exponent(rhs));
        return;
    }

    if constexpr (ulong_fits_uint64) {
        mpf_mul_ui(dst.get_mpf_t(), lhs.get_mpf_t(),
                   static_cast<unsigned long>(rhs));
    } else {
        if (fits_in_ulong(rhs)) {
            mpf_mul_ui(dst.get_mpf_t(), lhs.get_mpf_t(),
                       static_cast<unsigned long>(rhs));
        } else {
            mpf_class tmp = integer_tmp(rhs, dst.get_prec());
            mpf_mul(dst.get_mpf_t(), lhs.get_mpf_t(), tmp.get_mpf_t());
        }
    }
}

inline void div_mpf_uint(mpf_class& dst, mpf_class const& lhs, std::uint64_t rhs) {
    if (is_power_of_two(rhs)) {
        mpf_div_2exp(dst.get_mpf_t(), lhs.get_mpf_t(),
                     power_of_two_exponent(rhs));
        return;
    }

    if constexpr (ulong_fits_uint64) {
        mpf_div_ui(dst.get_mpf_t(), lhs.get_mpf_t(),
                   static_cast<unsigned long>(rhs));
    } else {
        if (fits_in_ulong(rhs)) {
            mpf_div_ui(dst.get_mpf_t(), lhs.get_mpf_t(),
                       static_cast<unsigned long>(rhs));
        } else {
            mpf_class tmp = integer_tmp(rhs, dst.get_prec());
            mpf_div(dst.get_mpf_t(), lhs.get_mpf_t(), tmp.get_mpf_t());
        }
    }
}

inline void div_uint_mpf(mpf_class& dst, std::uint64_t lhs, mpf_class const& rhs) {
    if constexpr (ulong_fits_uint64) {
        mpf_ui_div(dst.get_mpf_t(), static_cast<unsigned long>(lhs),
                   rhs.get_mpf_t());
    } else {
        if (fits_in_ulong(lhs)) {
            mpf_ui_div(dst.get_mpf_t(), static_cast<unsigned long>(lhs),
                       rhs.get_mpf_t());
        } else {
            mpf_class tmp = integer_tmp(lhs, dst.get_prec());
            mpf_div(dst.get_mpf_t(), tmp.get_mpf_t(), rhs.get_mpf_t());
        }
    }
}

inline void set_mpz_from_scalar(mpz_class& dst, std::int64_t v) {
    dst = mpz_class(v);
}

inline void set_mpz_from_scalar(mpz_class& dst, std::uint64_t v) {
    dst = mpz_class(v);
}

inline void set_mpq_from_scalar(mpq_class& dst, std::int64_t v) {
    dst = mpq_class(v);
}

inline void set_mpq_from_scalar(mpq_class& dst, std::uint64_t v) {
    mpz_class z(v);
    mpq_set_z(dst.get_mpq_t(), z.get_mpz_t());
}

inline void set_mpf_from_value(mpf_class& dst, mpz_class const& v) {
    mpf_set_z(dst.get_mpf_t(), v.get_mpz_t());
}

inline void set_mpf_from_value(mpf_class& dst, mpq_class const& v) {
    mpf_set_q(dst.get_mpf_t(), v.get_mpq_t());
}

inline void set_mpf_from_value(mpf_class& dst, double v) {
    mpf_set_d(dst.get_mpf_t(), v);
}

inline void set_mpf_from_value(mpf_class& dst, std::int64_t v) {
    mpz_class z(v);
    mpf_set_z(dst.get_mpf_t(), z.get_mpz_t());
}

inline void set_mpf_from_value(mpf_class& dst, std::uint64_t v) {
    mpz_class z(v);
    mpf_set_z(dst.get_mpf_t(), z.get_mpz_t());
}

template<class T>
inline mpz_class as_mpz(T const& v) {
    if constexpr (std::same_as<std::remove_cvref_t<T>, mpz_class>) {
        return v;
    } else {
        using N = scalar_normalize_t<T>;
        static_assert(!std::same_as<N, double>);
        return mpz_class(static_cast<N>(v));
    }
}

template<class T>
inline mpq_class as_mpq(T const& v) {
    if constexpr (std::same_as<std::remove_cvref_t<T>, mpq_class>) {
        return v;
    } else if constexpr (std::same_as<std::remove_cvref_t<T>, mpz_class>) {
        return mpq_class(v);
    } else {
        using N = scalar_normalize_t<T>;
        if constexpr (std::same_as<N, double>) {
            return mpq_class(static_cast<double>(v));
        } else if constexpr (std::same_as<N, std::int64_t>) {
            return mpq_class(static_cast<std::int64_t>(v));
        } else {
            mpz_class z(static_cast<std::uint64_t>(v));
            return mpq_class(z);
        }
    }
}

}  // namespace gmpxx_detail

struct add_op {
    template<class Dst, class L, class R>
    static void apply(Dst& dst, L const& lhs, R const& rhs);
    static void apply(mpf_class& dst, mpf_class const& lhs, mpf_class const& rhs);
    static void apply(mpf_class& dst, mpf_class const& lhs, std::uint64_t rhs);
    static void apply(mpf_class& dst, std::uint64_t lhs, mpf_class const& rhs);
    static void apply(mpf_class& dst, mpf_class const& lhs, std::int64_t rhs);
    static void apply(mpf_class& dst, std::int64_t lhs, mpf_class const& rhs);
    static void apply(mpf_class& dst, mpf_class const& lhs, double rhs);
    static void apply(mpf_class& dst, double lhs, mpf_class const& rhs);
};

struct sub_op {
    template<class Dst, class L, class R>
    static void apply(Dst& dst, L const& lhs, R const& rhs);
    static void apply(mpf_class& dst, mpf_class const& lhs, mpf_class const& rhs);
    static void apply(mpf_class& dst, mpf_class const& lhs, std::uint64_t rhs);
    static void apply(mpf_class& dst, std::uint64_t lhs, mpf_class const& rhs);
    static void apply(mpf_class& dst, mpf_class const& lhs, std::int64_t rhs);
    static void apply(mpf_class& dst, std::int64_t lhs, mpf_class const& rhs);
    static void apply(mpf_class& dst, mpf_class const& lhs, double rhs);
    static void apply(mpf_class& dst, double lhs, mpf_class const& rhs);
};

struct mul_op {
    template<class Dst, class L, class R>
    static void apply(Dst& dst, L const& lhs, R const& rhs);
    static void apply(mpf_class& dst, mpf_class const& lhs, mpf_class const& rhs);
    static void apply(mpf_class& dst, mpf_class const& lhs, std::uint64_t rhs);
    static void apply(mpf_class& dst, std::uint64_t lhs, mpf_class const& rhs);
    static void apply(mpf_class& dst, mpf_class const& lhs, std::int64_t rhs);
    static void apply(mpf_class& dst, std::int64_t lhs, mpf_class const& rhs);
    static void apply(mpf_class& dst, mpf_class const& lhs, double rhs);
    static void apply(mpf_class& dst, double lhs, mpf_class const& rhs);
};

struct div_op {
    template<class Dst, class L, class R>
    static void apply(Dst& dst, L const& lhs, R const& rhs);
    static void apply(mpf_class& dst, mpf_class const& lhs, mpf_class const& rhs);
    static void apply(mpf_class& dst, mpf_class const& lhs, std::uint64_t rhs);
    static void apply(mpf_class& dst, std::uint64_t lhs, mpf_class const& rhs);
    static void apply(mpf_class& dst, mpf_class const& lhs, std::int64_t rhs);
    static void apply(mpf_class& dst, std::int64_t lhs, mpf_class const& rhs);
    static void apply(mpf_class& dst, mpf_class const& lhs, double rhs);
    static void apply(mpf_class& dst, double lhs, mpf_class const& rhs);
};

struct neg_op {
    static void apply(mpf_class& dst, mpf_class const& x) {
        mpf_neg(dst.get_mpf_t(), x.get_mpf_t());
    }
    static void apply(mpz_class& dst, mpz_class const& x) {
        mpz_neg(dst.get_mpz_t(), x.get_mpz_t());
    }
    static void apply(mpq_class& dst, mpq_class const& x) {
        mpq_neg(dst.get_mpq_t(), x.get_mpq_t());
    }
};

struct pos_op {
    static void apply(mpf_class& dst, mpf_class const& x) {
        mpf_set(dst.get_mpf_t(), x.get_mpf_t());
    }
    static void apply(mpz_class& dst, mpz_class const& x) {
        mpz_set(dst.get_mpz_t(), x.get_mpz_t());
    }
    static void apply(mpq_class& dst, mpq_class const& x) {
        mpq_set(dst.get_mpq_t(), x.get_mpq_t());
    }
};

template<class Dst, class L, class R>
inline void add_op::apply(Dst& dst, L const& lhs, R const& rhs) {
    if constexpr (std::same_as<Dst, mpf_class>) {
        if constexpr (std::same_as<std::remove_cvref_t<L>, mpf_class>) {
            mpf_class tmp(dst.get_prec());
            gmpxx_detail::set_mpf_from_value(tmp, rhs);
            mpf_add(dst.get_mpf_t(), lhs.get_mpf_t(), tmp.get_mpf_t());
        } else if constexpr (std::same_as<std::remove_cvref_t<R>, mpf_class>) {
            mpf_class tmp(dst.get_prec());
            gmpxx_detail::set_mpf_from_value(tmp, lhs);
            mpf_add(dst.get_mpf_t(), tmp.get_mpf_t(), rhs.get_mpf_t());
        } else {
            mpf_class ltmp(dst.get_prec());
            mpf_class rtmp(dst.get_prec());
            gmpxx_detail::set_mpf_from_value(ltmp, lhs);
            gmpxx_detail::set_mpf_from_value(rtmp, rhs);
            mpf_add(dst.get_mpf_t(), ltmp.get_mpf_t(), rtmp.get_mpf_t());
        }
    } else if constexpr (std::same_as<Dst, mpz_class>) {
        if constexpr (std::same_as<std::remove_cvref_t<L>, mpz_class> &&
                      std::same_as<std::remove_cvref_t<R>, mpz_class>) {
            mpz_add(dst.get_mpz_t(), lhs.get_mpz_t(), rhs.get_mpz_t());
        } else {
            mpz_class ltmp = gmpxx_detail::as_mpz(lhs);
            mpz_class rtmp = gmpxx_detail::as_mpz(rhs);
            mpz_add(dst.get_mpz_t(), ltmp.get_mpz_t(), rtmp.get_mpz_t());
        }
    } else {
        if constexpr (std::same_as<std::remove_cvref_t<L>, mpq_class> &&
                      std::same_as<std::remove_cvref_t<R>, mpq_class>) {
            mpq_add(dst.get_mpq_t(), lhs.get_mpq_t(), rhs.get_mpq_t());
        } else {
            mpq_class ltmp = gmpxx_detail::as_mpq(lhs);
            mpq_class rtmp = gmpxx_detail::as_mpq(rhs);
            mpq_add(dst.get_mpq_t(), ltmp.get_mpq_t(), rtmp.get_mpq_t());
        }
    }
}

template<class Dst, class L, class R>
inline void sub_op::apply(Dst& dst, L const& lhs, R const& rhs) {
    if constexpr (std::same_as<Dst, mpf_class>) {
        if constexpr (std::same_as<std::remove_cvref_t<L>, mpf_class>) {
            mpf_class tmp(dst.get_prec());
            gmpxx_detail::set_mpf_from_value(tmp, rhs);
            mpf_sub(dst.get_mpf_t(), lhs.get_mpf_t(), tmp.get_mpf_t());
        } else if constexpr (std::same_as<std::remove_cvref_t<R>, mpf_class>) {
            mpf_class tmp(dst.get_prec());
            gmpxx_detail::set_mpf_from_value(tmp, lhs);
            mpf_sub(dst.get_mpf_t(), tmp.get_mpf_t(), rhs.get_mpf_t());
        } else {
            mpf_class ltmp(dst.get_prec());
            mpf_class rtmp(dst.get_prec());
            gmpxx_detail::set_mpf_from_value(ltmp, lhs);
            gmpxx_detail::set_mpf_from_value(rtmp, rhs);
            mpf_sub(dst.get_mpf_t(), ltmp.get_mpf_t(), rtmp.get_mpf_t());
        }
    } else if constexpr (std::same_as<Dst, mpz_class>) {
        if constexpr (std::same_as<std::remove_cvref_t<L>, mpz_class> &&
                      std::same_as<std::remove_cvref_t<R>, mpz_class>) {
            mpz_sub(dst.get_mpz_t(), lhs.get_mpz_t(), rhs.get_mpz_t());
        } else {
            mpz_class ltmp = gmpxx_detail::as_mpz(lhs);
            mpz_class rtmp = gmpxx_detail::as_mpz(rhs);
            mpz_sub(dst.get_mpz_t(), ltmp.get_mpz_t(), rtmp.get_mpz_t());
        }
    } else {
        if constexpr (std::same_as<std::remove_cvref_t<L>, mpq_class> &&
                      std::same_as<std::remove_cvref_t<R>, mpq_class>) {
            mpq_sub(dst.get_mpq_t(), lhs.get_mpq_t(), rhs.get_mpq_t());
        } else {
            mpq_class ltmp = gmpxx_detail::as_mpq(lhs);
            mpq_class rtmp = gmpxx_detail::as_mpq(rhs);
            mpq_sub(dst.get_mpq_t(), ltmp.get_mpq_t(), rtmp.get_mpq_t());
        }
    }
}

template<class Dst, class L, class R>
inline void mul_op::apply(Dst& dst, L const& lhs, R const& rhs) {
    if constexpr (std::same_as<Dst, mpf_class>) {
        if constexpr (std::same_as<std::remove_cvref_t<L>, mpf_class>) {
            mpf_class tmp(dst.get_prec());
            gmpxx_detail::set_mpf_from_value(tmp, rhs);
            mpf_mul(dst.get_mpf_t(), lhs.get_mpf_t(), tmp.get_mpf_t());
        } else if constexpr (std::same_as<std::remove_cvref_t<R>, mpf_class>) {
            mpf_class tmp(dst.get_prec());
            gmpxx_detail::set_mpf_from_value(tmp, lhs);
            mpf_mul(dst.get_mpf_t(), tmp.get_mpf_t(), rhs.get_mpf_t());
        } else {
            mpf_class ltmp(dst.get_prec());
            mpf_class rtmp(dst.get_prec());
            gmpxx_detail::set_mpf_from_value(ltmp, lhs);
            gmpxx_detail::set_mpf_from_value(rtmp, rhs);
            mpf_mul(dst.get_mpf_t(), ltmp.get_mpf_t(), rtmp.get_mpf_t());
        }
    } else if constexpr (std::same_as<Dst, mpz_class>) {
        if constexpr (std::same_as<std::remove_cvref_t<L>, mpz_class> &&
                      std::same_as<std::remove_cvref_t<R>, mpz_class>) {
            mpz_mul(dst.get_mpz_t(), lhs.get_mpz_t(), rhs.get_mpz_t());
        } else {
            mpz_class ltmp = gmpxx_detail::as_mpz(lhs);
            mpz_class rtmp = gmpxx_detail::as_mpz(rhs);
            mpz_mul(dst.get_mpz_t(), ltmp.get_mpz_t(), rtmp.get_mpz_t());
        }
    } else {
        if constexpr (std::same_as<std::remove_cvref_t<L>, mpq_class> &&
                      std::same_as<std::remove_cvref_t<R>, mpq_class>) {
            mpq_mul(dst.get_mpq_t(), lhs.get_mpq_t(), rhs.get_mpq_t());
        } else {
            mpq_class ltmp = gmpxx_detail::as_mpq(lhs);
            mpq_class rtmp = gmpxx_detail::as_mpq(rhs);
            mpq_mul(dst.get_mpq_t(), ltmp.get_mpq_t(), rtmp.get_mpq_t());
        }
    }
}

template<class Dst, class L, class R>
inline void div_op::apply(Dst& dst, L const& lhs, R const& rhs) {
    if constexpr (std::same_as<Dst, mpf_class>) {
        if constexpr (std::same_as<std::remove_cvref_t<L>, mpf_class>) {
            mpf_class tmp(dst.get_prec());
            gmpxx_detail::set_mpf_from_value(tmp, rhs);
            mpf_div(dst.get_mpf_t(), lhs.get_mpf_t(), tmp.get_mpf_t());
        } else if constexpr (std::same_as<std::remove_cvref_t<R>, mpf_class>) {
            mpf_class tmp(dst.get_prec());
            gmpxx_detail::set_mpf_from_value(tmp, lhs);
            mpf_div(dst.get_mpf_t(), tmp.get_mpf_t(), rhs.get_mpf_t());
        } else {
            mpf_class ltmp(dst.get_prec());
            mpf_class rtmp(dst.get_prec());
            gmpxx_detail::set_mpf_from_value(ltmp, lhs);
            gmpxx_detail::set_mpf_from_value(rtmp, rhs);
            mpf_div(dst.get_mpf_t(), ltmp.get_mpf_t(), rtmp.get_mpf_t());
        }
    } else if constexpr (std::same_as<Dst, mpz_class>) {
        if constexpr (std::same_as<std::remove_cvref_t<L>, mpz_class> &&
                      std::same_as<std::remove_cvref_t<R>, mpz_class>) {
            mpz_tdiv_q(dst.get_mpz_t(), lhs.get_mpz_t(), rhs.get_mpz_t());
        } else {
            mpz_class ltmp = gmpxx_detail::as_mpz(lhs);
            mpz_class rtmp = gmpxx_detail::as_mpz(rhs);
            mpz_tdiv_q(dst.get_mpz_t(), ltmp.get_mpz_t(), rtmp.get_mpz_t());
        }
    } else {
        if constexpr (std::same_as<std::remove_cvref_t<L>, mpq_class> &&
                      std::same_as<std::remove_cvref_t<R>, mpq_class>) {
            mpq_div(dst.get_mpq_t(), lhs.get_mpq_t(), rhs.get_mpq_t());
        } else {
            mpq_class ltmp = gmpxx_detail::as_mpq(lhs);
            mpq_class rtmp = gmpxx_detail::as_mpq(rhs);
            mpq_div(dst.get_mpq_t(), ltmp.get_mpq_t(), rtmp.get_mpq_t());
        }
    }
}

inline void add_op::apply(mpf_class& dst, mpf_class const& lhs,
                          mpf_class const& rhs) {
    mpf_add(dst.get_mpf_t(), lhs.get_mpf_t(), rhs.get_mpf_t());
}

inline void add_op::apply(mpf_class& dst, mpf_class const& lhs,
                          std::uint64_t rhs) {
    gmpxx_detail::add_mpf_uint(dst, lhs, rhs);
}

inline void add_op::apply(mpf_class& dst, std::uint64_t lhs,
                          mpf_class const& rhs) {
    apply(dst, rhs, lhs);
}

inline void add_op::apply(mpf_class& dst, mpf_class const& lhs,
                          std::int64_t rhs) {
    if (rhs >= 0) {
        apply(dst, lhs, static_cast<std::uint64_t>(rhs));
    } else {
        sub_op::apply(dst, lhs, gmpxx_detail::safe_negate(rhs));
    }
}

inline void add_op::apply(mpf_class& dst, std::int64_t lhs,
                          mpf_class const& rhs) {
    apply(dst, rhs, lhs);
}

inline void add_op::apply(mpf_class& dst, mpf_class const& lhs, double rhs) {
    mpf_class tmp = gmpxx_detail::double_tmp(rhs, dst.get_prec());
    mpf_add(dst.get_mpf_t(), lhs.get_mpf_t(), tmp.get_mpf_t());
}

inline void add_op::apply(mpf_class& dst, double lhs, mpf_class const& rhs) {
    apply(dst, rhs, lhs);
}

inline void sub_op::apply(mpf_class& dst, mpf_class const& lhs,
                          mpf_class const& rhs) {
    mpf_sub(dst.get_mpf_t(), lhs.get_mpf_t(), rhs.get_mpf_t());
}

inline void sub_op::apply(mpf_class& dst, mpf_class const& lhs,
                          std::uint64_t rhs) {
    gmpxx_detail::sub_mpf_uint(dst, lhs, rhs);
}

inline void sub_op::apply(mpf_class& dst, std::uint64_t lhs,
                          mpf_class const& rhs) {
    gmpxx_detail::sub_uint_mpf(dst, lhs, rhs);
}

inline void sub_op::apply(mpf_class& dst, mpf_class const& lhs,
                          std::int64_t rhs) {
    if (rhs >= 0) {
        apply(dst, lhs, static_cast<std::uint64_t>(rhs));
    } else {
        add_op::apply(dst, lhs, gmpxx_detail::safe_negate(rhs));
    }
}

inline void sub_op::apply(mpf_class& dst, std::int64_t lhs,
                          mpf_class const& rhs) {
    if (lhs >= 0) {
        apply(dst, static_cast<std::uint64_t>(lhs), rhs);
    } else {
        add_op::apply(dst, rhs, gmpxx_detail::safe_negate(lhs));
        mpf_neg(dst.get_mpf_t(), dst.get_mpf_t());
    }
}

inline void sub_op::apply(mpf_class& dst, mpf_class const& lhs, double rhs) {
    mpf_class tmp = gmpxx_detail::double_tmp(rhs, dst.get_prec());
    mpf_sub(dst.get_mpf_t(), lhs.get_mpf_t(), tmp.get_mpf_t());
}

inline void sub_op::apply(mpf_class& dst, double lhs, mpf_class const& rhs) {
    mpf_class tmp = gmpxx_detail::double_tmp(lhs, dst.get_prec());
    mpf_sub(dst.get_mpf_t(), tmp.get_mpf_t(), rhs.get_mpf_t());
}

inline void mul_op::apply(mpf_class& dst, mpf_class const& lhs,
                          mpf_class const& rhs) {
    mpf_mul(dst.get_mpf_t(), lhs.get_mpf_t(), rhs.get_mpf_t());
}

inline void mul_op::apply(mpf_class& dst, mpf_class const& lhs,
                          std::uint64_t rhs) {
    gmpxx_detail::mul_mpf_uint(dst, lhs, rhs);
}

inline void mul_op::apply(mpf_class& dst, std::uint64_t lhs,
                          mpf_class const& rhs) {
    apply(dst, rhs, lhs);
}

inline void mul_op::apply(mpf_class& dst, mpf_class const& lhs,
                          std::int64_t rhs) {
    if (rhs >= 0) {
        apply(dst, lhs, static_cast<std::uint64_t>(rhs));
    } else {
        apply(dst, lhs, gmpxx_detail::safe_negate(rhs));
        mpf_neg(dst.get_mpf_t(), dst.get_mpf_t());
    }
}

inline void mul_op::apply(mpf_class& dst, std::int64_t lhs,
                          mpf_class const& rhs) {
