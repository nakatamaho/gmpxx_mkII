[[nodiscard]] inline mpz_class operator%(mpz_class const& l,
                                         mpz_class const& r) {
    mpz_class result;
    mpz_tdiv_r(result.get_mpz_t(), l.get_mpz_t(), r.get_mpz_t());
    return result;
}

template<scalar_operand R>
    requires (!std::same_as<scalar_normalize_t<R>, double>)
[[nodiscard]] inline mpz_class operator%(mpz_class const& l, R const& r) {
    using NR = scalar_normalize_t<R>;
    return l % mpz_class(static_cast<NR>(r));
}

template<scalar_operand L>
    requires (!std::same_as<scalar_normalize_t<L>, double>)
[[nodiscard]] inline mpz_class operator%(L const& l, mpz_class const& r) {
    using NL = scalar_normalize_t<L>;
    return mpz_class(static_cast<NL>(l)) % r;
}

template<phase0_operand X>
[[nodiscard]] inline auto operator-(X const& x) {
    return unary_expr<neg_op, std::remove_cvref_t<X>>{x};
}

template<phase2_operand X>
    requires (!phase0_operand<X> && !scalar_operand<X>)
[[nodiscard]] inline auto operator-(X const& x) {
    return unary_expr<neg_op, std::remove_cvref_t<X>>{x};
}

template<class X>
[[nodiscard]] inline auto operator-(unary_expr<neg_op, X> const& x) {
    return unary_expr<pos_op, X>{x.operand()};
}

template<phase0_operand X>
[[nodiscard]] inline auto operator+(X const& x) {
    return unary_expr<pos_op, std::remove_cvref_t<X>>{x};
}

template<phase2_operand X>
    requires (!phase0_operand<X> && !scalar_operand<X>)
[[nodiscard]] inline auto operator+(X const& x) {
    return unary_expr<pos_op, std::remove_cvref_t<X>>{x};
}

[[nodiscard]] inline mpf_class sqrt(mpf_class const& x) {
    mpf_class result(x.get_prec());
    mpf_sqrt(result.get_mpf_t(), x.get_mpf_t());
    return result;
}

[[nodiscard]] inline mpf_class abs(mpf_class const& x) {
    mpf_class result(x.get_prec());
    mpf_abs(result.get_mpf_t(), x.get_mpf_t());
    return result;
}

[[nodiscard]] inline mpf_class neg(mpf_class const& x) {
    mpf_class result(x.get_prec());
    mpf_neg(result.get_mpf_t(), x.get_mpf_t());
    return result;
}

namespace gmpxx_mkII {

using ::binary_expr;
using ::abs;
using ::cmp;
using ::div_op;
using ::gmpxx_defaults;
using ::mpf_class;
using ::mpq_class;
using ::mpz_class;
using ::mul_op;
using ::neg_op;
using ::neg;
using ::pos_op;
using ::sqrt;
using ::unary_expr;

namespace literals {

inline mpz_class operator""_mpz(unsigned long long value) {
    return mpz_class(static_cast<std::uint64_t>(value));
}

inline mpz_class operator""_mpz(char const* text) {
    return mpz_class(text, 10);
}

inline mpz_class operator""_mpz(char const* text, std::size_t) {
    return mpz_class(text);
}

inline mpq_class operator""_mpq(unsigned long long value) {
    return mpq_class(mpz_class(static_cast<std::uint64_t>(value)));
}

inline mpq_class operator""_mpq(char const* text) {
    return mpq_class(text, 10);
}

inline mpq_class operator""_mpq(char const* text, std::size_t) {
    return mpq_class(text);
}

inline mpf_class operator""_mpf(char const* text) {
    return mpf_class(text, gmpxx_mkII_detail::checked_mp_bitcnt(
                               gmpxx_mkII_detail::thread_default_prec()),
                     10);
}

inline mpf_class operator""_mpf(char const* text, std::size_t) {
    return mpf_class(text);
}

}  // namespace literals

}  // namespace gmpxx_mkII
