template<phase0_operand L, phase0_operand R>
[[nodiscard]] inline auto operator/(L const& l, R const& r) {
    return binary_expr<div_op, std::remove_cvref_t<L>, std::remove_cvref_t<R>>{l, r};
}

template<phase1_operand L, scalar_operand R>
    requires (!scalar_operand<L>)
[[nodiscard]] inline auto operator/(L const& l, R const& r) {
    using NR = scalar_normalize_t<R>;
    return binary_expr<div_op, std::remove_cvref_t<L>, NR>{
        l, static_cast<NR>(r)};
}

template<scalar_operand L, phase1_operand R>
    requires (!scalar_operand<R>)
[[nodiscard]] inline auto operator/(L const& l, R const& r) {
    using NL = scalar_normalize_t<L>;
    return binary_expr<div_op, NL, std::remove_cvref_t<R>>{
        static_cast<NL>(l), r};
}

template<phase2_operand L, phase2_operand R>
    requires (!(phase1_operand<L> && phase1_operand<R>) &&
              !(scalar_operand<L> && scalar_operand<R>))
[[nodiscard]] inline auto operator/(L const& l, R const& r) {
    using NL = gmpxx_mkII_detail::operand_storage_t<L>;
    using NR = gmpxx_mkII_detail::operand_storage_t<R>;
    if constexpr (scalar_operand<L> && !scalar_operand<R>) {
        return binary_expr<div_op, NL, std::remove_cvref_t<R>>{
            static_cast<NL>(l), r};
    } else if constexpr (!scalar_operand<L> && scalar_operand<R>) {
        return binary_expr<div_op, std::remove_cvref_t<L>, NR>{
            l, static_cast<NR>(r)};
    } else {
        return binary_expr<div_op, std::remove_cvref_t<L>, std::remove_cvref_t<R>>{
            l, r};
    }
}

[[nodiscard]] inline mpz_class operator%(mpz_class const& l,
                                         mpz_class const& r) {
    mpz_class result;
    mpz_tdiv_r(result.get_mpz_t(), l.get_mpz_t(), r.get_mpz_t());
    return result;
}

template<scalar_operand R>
    requires (!std::same_as<scalar_normalize_t<R>, double>)
[[nodiscard]] inline mpz_class operator%(mpz_class const& l, R const& r) {
    using NR = scalar_normalize_t<R>;
    return l % mpz_class(static_cast<NR>(r));
}

template<scalar_operand L>
    requires (!std::same_as<scalar_normalize_t<L>, double>)
[[nodiscard]] inline mpz_class operator%(L const& l, mpz_class const& r) {
    using NL = scalar_normalize_t<L>;
    return mpz_class(static_cast<NL>(l)) % r;
}

template<phase0_operand X>
[[nodiscard]] inline auto operator-(X const& x) {
    return unary_expr<neg_op, std::remove_cvref_t<X>>{x};
}

template<phase2_operand X>
    requires (!phase0_operand<X> && !scalar_operand<X>)
[[nodiscard]] inline auto operator-(X const& x) {
    return unary_expr<neg_op, std::remove_cvref_t<X>>{x};
}

template<class X>
[[nodiscard]] inline auto operator-(unary_expr<neg_op, X> const& x) {
    return unary_expr<pos_op, X>{x.operand()};
}

template<phase0_operand X>
[[nodiscard]] inline auto operator+(X const& x) {
    return unary_expr<pos_op, std::remove_cvref_t<X>>{x};
}

template<phase2_operand X>
    requires (!phase0_operand<X> && !scalar_operand<X>)
[[nodiscard]] inline auto operator+(X const& x) {
    return unary_expr<pos_op, std::remove_cvref_t<X>>{x};
}
