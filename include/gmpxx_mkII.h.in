}

inline mpz_class& mpz_class::operator+=(mpz_class const& rhs) {
    mpz_add(value, value, rhs.value);
    return *this;
}

inline mpz_class& mpz_class::operator-=(mpz_class const& rhs) {
    mpz_sub(value, value, rhs.value);
    return *this;
}

inline mpz_class& mpz_class::operator*=(mpz_class const& rhs) {
    mpz_mul(value, value, rhs.value);
