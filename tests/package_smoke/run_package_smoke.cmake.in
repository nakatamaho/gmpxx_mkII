# SPDX-License-Identifier: BSD-2-Clause

set(prefix "@CMAKE_CURRENT_BINARY_DIR@/package_smoke_install")
set(consumer_build "@CMAKE_CURRENT_BINARY_DIR@/package_smoke_build")

file(REMOVE_RECURSE "${prefix}" "${consumer_build}")

execute_process(
    COMMAND "@CMAKE_COMMAND@" --install "@CMAKE_BINARY_DIR@" --prefix "${prefix}"
    RESULT_VARIABLE install_result)
if(NOT install_result EQUAL 0)
    message(FATAL_ERROR "gmpxx_mkII install failed")
endif()

execute_process(
    COMMAND "@CMAKE_COMMAND@"
            -S "@CMAKE_CURRENT_SOURCE_DIR@/package_smoke"
            -B "${consumer_build}"
            -DCMAKE_PREFIX_PATH=${prefix}
    RESULT_VARIABLE configure_result)
if(NOT configure_result EQUAL 0)
    message(FATAL_ERROR "package smoke configure failed")
endif()

execute_process(
    COMMAND "@CMAKE_COMMAND@" --build "${consumer_build}" -j
    RESULT_VARIABLE build_result)
if(NOT build_result EQUAL 0)
    message(FATAL_ERROR "package smoke build failed")
endif()

execute_process(
    COMMAND "@CMAKE_CTEST_COMMAND@" --test-dir "${consumer_build}" --output-on-failure
    RESULT_VARIABLE test_result)
if(NOT test_result EQUAL 0)
    message(FATAL_ERROR "package smoke test failed")
endif()
